@model List<WebDocTruyen.Application.DTOs.Favorite.FavoriteDto>
@using System.Security.Claims
@{
    ViewData["Title"] = "Truyện đang theo dõi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="mb-0 fw-semibold" style="font-size:22px;">Truyện đang theo dõi</h2>
            <p class="text-muted mb-0 mt-1" style="font-size:14px;">
                @Model.Count truyện
            </p>
        </div>
        <a asp-controller="Story" asp-action="Index" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-compass me-1"></i>Khám phá thêm
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="myfav-empty">
            <div class="myfav-empty-icon">
                <i class="bi bi-bookmark-heart"></i>
            </div>
            <h5 class="mt-3 mb-1">Chưa theo dõi truyện nào</h5>
            <p class="text-muted mb-3" style="font-size:14px;">
                Bấm ❤️ trên trang truyện để thêm vào danh sách theo dõi.
            </p>
            <a asp-controller="Story" asp-action="Index" class="btn btn-primary btn-sm">
                <i class="bi bi-compass me-1"></i>Khám phá truyện
            </a>
        </div>
    }
    else
    {
        <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-3" id="favGrid">
            @foreach (var fav in Model)
            {
                <div class="col fav-item" data-id="@fav.FavoriteId" data-story="@fav.StoryId">
                    <div class="fav-card">
                        <div class="fav-thumb-wrap">
                            <img src="@fav.CoverImage" alt="@fav.StoryTitle" class="fav-thumb"
                                 onerror="this.src='/images/default.jpg'" />

                            <span class="fav-status-badge @(fav.Status == "completed" ? "badge-done" : "badge-ongoing")">
                                @(fav.Status == "completed" ? "Hoàn thành" : "Đang ra")
                            </span>

                            <button class="fav-remove-btn" title="Bỏ theo dõi"
                                    onclick="removeFav(this, @fav.StoryId, @fav.FavoriteId)">
                                <i class="bi bi-heart-fill"></i>
                            </button>
                        </div>

                        <div class="fav-info">
                            <a asp-controller="Story" asp-action="Details" asp-route-id="@fav.StoryId"
                               class="fav-title" title="@fav.StoryTitle">@fav.StoryTitle</a>
                            <span class="fav-meta">
                                <i class="bi bi-collection me-1"></i>@fav.ChapterCount chương
                            </span>
                        </div>

                        <a asp-controller="Chapter" asp-action="ListChapters" asp-route-id="@fav.StoryId"
                           class="fav-read-btn">
                            <i class="bi bi-book-half me-1"></i>Đọc tiếp
                        </a>
                    </div>
                </div>
            }
        </div>

        <p class="text-muted text-center mt-4" style="font-size:13px;" id="emptyHint" hidden>
            Danh sách theo dõi trống. <a asp-controller="Story" asp-action="Index">Khám phá thêm</a>
        </p>
    }
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        const token = () => document.querySelector('input[name=__RequestVerificationToken]')?.value ?? '';

        async function removeFav(btn, storyId, favId) {
            btn.disabled = true;
            try {
                const resp = await fetch('/Story/ToggleFavorite', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token()
                    },
                    body: `storyId=${storyId}`
                });
                if (!resp.ok) return;

                const card = btn.closest('.fav-item');
                card.style.transition = 'opacity .25s, transform .25s';
                card.style.opacity = '0';
                card.style.transform = 'scale(.92)';
                setTimeout(() => {
                    card.remove();
                    const remaining = document.querySelectorAll('.fav-item').length;
                    document.querySelector('.text-muted.mb-0.mt-1').textContent = remaining + ' truyện';
                    if (remaining === 0) {
                        document.getElementById('favGrid')?.remove();
                        document.getElementById('emptyHint')?.removeAttribute('hidden');
                    }
                }, 260);
            } catch {
                btn.disabled = false;
            }
        }
    </script>

    <style>
        /* ── Empty state ── */
        .myfav-empty {
            text-align: center;
            padding: 64px 24px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
        }

        .myfav-empty-icon {
            width: 64px;
            height: 64px;
            background: var(--brand-light);
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: var(--brand);
        }

        /* ── Card ── */
        .fav-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 100%;
            transition: transform .18s, box-shadow .18s;
        }

            .fav-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 24px rgba(0,0,0,.09);
            }

        /* ── Thumbnail ── */
        .fav-thumb-wrap {
            position: relative;
            overflow: hidden;
            aspect-ratio: 2/3;
            background: var(--bg);
        }

        .fav-thumb {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform .4s ease;
        }

        .fav-card:hover .fav-thumb {
            transform: scale(1.05);
        }

        /* Status badge */
        .fav-status-badge {
            position: absolute;
            top: 8px;
            left: 8px;
            font-size: 10px;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 20px;
        }

        .badge-done {
            background: #dcfce7;
            color: #166534;
        }

        .badge-ongoing {
            background: #fef9c3;
            color: #854d0e;
        }

        /* Remove button */
        .fav-remove-btn {
            position: absolute;
            top: 8px;
            right: 8px;
            width: 28px;
            height: 28px;
            border-radius: 8px;
            background: rgba(255,255,255,.88);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            color: #e11d48;
            opacity: 0;
            transition: opacity .15s, background .15s;
        }

        .fav-card:hover .fav-remove-btn {
            opacity: 1;
        }

        .fav-remove-btn:hover {
            background: #fff;
        }

        /* ── Info ── */
        .fav-info {
            padding: 10px 12px 6px;
            flex: 1;
        }

        .fav-title {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: var(--text-primary);
            text-decoration: none;
            line-height: 1.4;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            margin-bottom: 4px;
        }

            .fav-title:hover {
                color: var(--brand);
            }

        .fav-meta {
            font-size: 12px;
            color: var(--text-muted);
        }

        /* ── Read button ── */
        .fav-read-btn {
            display: block;
            margin: 0 10px 10px;
            padding: 7px;
            text-align: center;
            font-size: 12px;
            font-weight: 500;
            background: var(--brand-light);
            color: var(--brand);
            border-radius: var(--radius-sm);
            text-decoration: none;
            transition: background .15s, color .15s;
        }

            .fav-read-btn:hover {
                background: var(--brand);
                color: #fff;
            }
    </style>
}