@model List<WebDocTruyen.Application.DTOs.Favorite.FavoriteDto>
@using System.Security.Claims
@{
    ViewData["Title"] = "Truyện đang theo dõi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Scripts {
    @Html.AntiForgeryToken()

    <link rel="stylesheet" href="~/css/my-favorites.css" />

    <script>
        const __favToken = () =>
            document.querySelector('input[name=__RequestVerificationToken]')?.value ?? '';

        async function removeFav(btn, storyId) {
            btn.disabled = true;
            try {
                const resp = await fetch('/Story/ToggleFavorite', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': __favToken()
                    },
                    body: `storyId=${storyId}`
                });
                if (!resp.ok) { btn.disabled = false; return; }

                const card = btn.closest('.fav-item');
                card.style.transition = 'opacity .28s, transform .28s';
                card.style.opacity = '0';
                card.style.transform = 'scale(.88) translateY(-4px)';
                setTimeout(() => {
                    card.remove();
                    const remaining = document.querySelectorAll('.fav-item').length;
                    const sub = document.getElementById('favSubCount');
                    if (sub) sub.textContent = remaining + ' truyện';
                    if (remaining === 0) {
                        document.getElementById('favGrid')?.remove();
                        document.getElementById('favEmptyHint')?.removeAttribute('hidden');
                    }
                }, 280);
            } catch {
                btn.disabled = false;
            }
        }
    </script>
}

<div class="container mt-3">
    <div class="fav-page">

        <!-- ── Hero header ── -->
        <div class="fav-header">
            <div class="fav-header-bg"></div>
            <div class="fav-header-grid"></div>

            <div class="fav-header-inner">
                <div class="fav-header-left">
                    <div class="fav-heading-tag">
                        <span class="fav-heading-dot"></span>
                        Thư viện cá nhân
                    </div>
                    <h2 class="fav-heading">
						<span>Truyện đang theo dõi</span>
                    </h2>
                    <p class="fav-sub" id="favSubCount">@Model.Count truyện</p>
                </div>

                <a asp-controller="Story" asp-action="Index" class="fav-explore-btn">
                    <i class="bi bi-compass-fill"></i> Khám phá thêm
                </a>
            </div>

            @if (Model.Any())
            {
                var doneCount = Model.Count(f => f.Status == "completed");
                var ongoingCount = Model.Count(f => f.Status != "completed");
                var continueCount = Model.Count(f => f.LastReadChapterId.HasValue);
                <div class="fav-stats">
                    <div class="fav-stat">
                        <div class="fav-stat-icon fav-stat-icon-purple">
                            <i class="bi bi-bookmark-heart-fill"></i>
                        </div>
                        <span><strong>@ongoingCount</strong> đang ra</span>
                    </div>
                    <div class="fav-stat">
                        <div class="fav-stat-icon fav-stat-icon-cyan">
                            <i class="bi bi-check-circle-fill"></i>
                        </div>
                        <span><strong>@doneCount</strong> hoàn thành</span>
                    </div>
                    <div class="fav-stat">
                        <div class="fav-stat-icon fav-stat-icon-pink">
                            <i class="bi bi-play-circle-fill"></i>
                        </div>
                        <span><strong>@continueCount</strong> đang đọc dở</span>
                    </div>
                </div>
            }
        </div>

        <!-- ── Story grid ── -->
        @if (!Model.Any())
        {
            <div class="fav-empty" id="favEmptyHint">
                <div class="fav-empty-icon">🔖</div>
                <h5>Chưa theo dõi truyện nào</h5>
                <p>Bấm ❤️ trên trang truyện để thêm vào danh sách theo dõi.</p>
                <a asp-controller="Story" asp-action="Index" class="fav-empty-btn">
                    <i class="bi bi-compass-fill"></i> Khám phá truyện
                </a>
            </div>
        }
        else
        {
            <div class="fav-grid" id="favGrid">
                @foreach (var fav in Model)
                {
                    <div class="col fav-item" data-id="@fav.FavoriteId" data-story="@fav.StoryId">
                        <div class="fav-card">

                            <div class="fav-thumb-wrap">
                                <img src="@fav.CoverImage"
                                     alt="@fav.StoryTitle"
                                     class="fav-thumb"
                                     onerror="this.src='/images/default.jpg'" />
                                <div class="fav-thumb-overlay"></div>

                                <span class="fav-status-badge @(fav.Status == "completed" ? "badge-done" : "badge-going")">
                                    @(fav.Status == "completed" ? "Xong" : "Đang ra")
                                </span>

                                <span class="fav-chap-badge">
                                    <i class="bi bi-collection" style="font-size:9px;"></i>
                                    @fav.ChapterCount ch.
                                </span>

                                <button class="fav-remove-btn"
                                        title="Bỏ theo dõi"
                                        onclick="removeFav(this, @fav.StoryId)">
                                    <i class="bi bi-heart-fill"></i>
                                </button>
                            </div>

                            <div class="fav-info">
                                <a asp-controller="Story" asp-action="Details"
                                   asp-route-id="@fav.StoryId"
                                   class="fav-title"
                                   title="@fav.StoryTitle">@fav.StoryTitle</a>
                                <span class="fav-meta">
                                    <i class="bi bi-collection" style="font-size:11px;"></i>
                                    @fav.ChapterCount chương
                                </span>
                            </div>

                            @if (fav.LastReadChapterId.HasValue)
                            {
                                <a asp-controller="Chapter"
                                   asp-action="ReadChapter"
                                   asp-route-id="@fav.LastReadChapterId"
                                   class="fav-read-btn">
                                    <i class="bi bi-play-fill"></i>
                                    Đọc tiếp (Ch.@fav.LastReadChapterNumber)
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Chapter"
                                   asp-action="ListChapters"
                                   asp-route-id="@fav.StoryId"
                                   class="fav-read-btn">
                                    <i class="bi bi-book-half"></i>
                                    Bắt đầu đọc
                                </a>
                            }

                        </div>
                    </div>
                }
            </div>

            <p class="text-muted text-center mt-4" style="font-size:13px;" id="favEmptyHint" hidden>
                Danh sách trống.
                <a asp-controller="Story" asp-action="Index">Khám phá thêm</a>
            </p>
        }

    </div>
</div>
