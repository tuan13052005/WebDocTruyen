@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/login.css" />

<div class="auth-page">
    <div class="auth-blob auth-blob-1"></div>
    <div class="auth-blob auth-blob-2"></div>
    <div class="auth-blob auth-blob-3"></div>
    <div class="auth-halftone"></div>
    <div class="auth-slash auth-slash1"></div>
    <div class="auth-slash auth-slash2"></div>
    <div class="auth-slash auth-slash3"></div>
    <div id="authDoodles"></div>

    <div class="auth-card">

        <!-- Mascot peeking over the card -->
        <div class="auth-mascot" aria-hidden="true">
            <span class="mascot-face">(｡•ᴗ•｡)</span>
            <span class="auth-mascot-spark s1">✦</span>
            <span class="auth-mascot-spark s2">✧</span>
        </div>

        <div class="auth-card-inner">
            <div class="auth-card-header">
                <div class="auth-burst"></div>
                <a asp-controller="Home" asp-action="Index" class="auth-brand">
                    <div class="auth-brand-icon">📖</div>
                    <span class="auth-brand-name">Web Đọc Truyện</span>
                </a>
                <div class="auth-card-title">
                    Chào mừng trở lại <span class="wave">👋</span>
                </div>
                <div class="auth-card-sub">Đăng nhập để tiếp tục cuộc phiêu lưu của bạn</div>
            </div>

            <div class="auth-body">
                @if (TempData["Success"] != null)
                {
                    <div class="auth-alert auth-alert-success">
                        <i class="bi bi-check-circle"></i> @TempData["Success"]
                    </div>
                }
                @if (ViewBag.Error != null)
                {
                    <div class="auth-alert" id="authErr">
                        <i class="bi bi-exclamation-circle"></i> @ViewBag.Error
                    </div>
                }

                <form asp-action="Login" asp-controller="Account" method="post" id="loginForm">
                    @Html.AntiForgeryToken()
                    @if (ViewBag.ReturnUrl != null)
                    {
                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    }

                    <div class="auth-field">
                        <label>Email</label>
                        <div class="auth-fw">
                            <i class="bi bi-envelope auth-fi"></i>
                            <input type="email" name="Email" required autocomplete="email" placeholder="ten@email.com" />
                        </div>
                    </div>

                    <div class="auth-field">
                        <label>Mật khẩu</label>
                        <div class="auth-fw">
                            <i class="bi bi-lock auth-fi"></i>
                            <input type="password" name="Password" required autocomplete="current-password" placeholder="••••••••" />
                        </div>
                    </div>

                    <button type="submit" class="auth-btn" id="loginBtn">
                        <i class="bi bi-box-arrow-in-right btn-icon"></i> Đăng nhập
                    </button>
                </form>

                <p class="auth-link-row">
                    Chưa có tài khoản?
                    <a asp-controller="Account" asp-action="Register">Đăng ký ngay</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            // ── Floating doodle stickers ──
            if (!reduceMotion) {
                var dw = document.getElementById('authDoodles');
                var doodles = [
                    { g: '✨', s: 20, l: 8,  t: 68, d: 8,  dl: 0 },
                    { g: '💫', s: 18, l: 88, t: 20, d: 9,  dl: .8 },
                    { g: '📚', s: 22, l: 15, t: 18, d: 10, dl: 1.4 },
                    { g: '💕', s: 16, l: 92, t: 62, d: 7.5, dl: .4 },
                    { g: '⭐', s: 15, l: 6,  t: 40, d: 8.5, dl: 1.9 }
                ];
                doodles.forEach(function (c) {
                    var el = document.createElement('span');
                    el.className = 'auth-doodle';
                    el.textContent = c.g;
                    el.style.cssText =
                        'font-size:' + c.s + 'px;left:' + c.l + '%;top:' + c.t + '%;' +
                        'animation-duration:' + c.d + 's, ' + (c.d * .8) + 's;' +
                        'animation-delay:' + c.dl + 's, ' + c.dl + 's;';
                    dw.appendChild(el);
                });
            }

            // ── Error alert auto-fade ──
            var err = document.getElementById('authErr');
            if (err) setTimeout(function () { err.style.transition = 'opacity .4s'; err.style.opacity = '0'; }, 4000);

            // ── Confetti burst on submit ──
            var btn = document.getElementById('loginBtn');
            if (btn && !reduceMotion) {
                btn.addEventListener('click', function (e) {
                    var rect = btn.getBoundingClientRect();
                    var cx = rect.left + rect.width / 2;
                    var cy = rect.top + rect.height / 2;
                    var colors = ['#7c3aed', '#ec4899', '#fbbf24', '#67e8f9', '#a78bfa'];

                    for (var i = 0; i < 16; i++) {
                        var piece = document.createElement('span');
                        piece.className = 'auth-confetti-piece';
                        var angle = Math.random() * Math.PI * 2;
                        var dist = 60 + Math.random() * 70;
                        var ex = Math.cos(angle) * dist;
                        var ey = Math.sin(angle) * dist - 20;
                        piece.style.setProperty('--confetti-end', 'translate(' + ex + 'px,' + ey + 'px)');
                        piece.style.setProperty('--confetti-rot', (Math.random() * 480 - 240) + 'deg');
                        piece.style.left = cx + 'px';
                        piece.style.top = cy + 'px';
                        piece.style.width = (4 + Math.random() * 5) + 'px';
                        piece.style.height = (4 + Math.random() * 5) + 'px';
                        piece.style.background = colors[i % colors.length];
                        document.body.appendChild(piece);
                        (function (p) { setTimeout(function () { p.remove(); }, 820); })(piece);
                    }
                });
            }
        })();
    </script>
}