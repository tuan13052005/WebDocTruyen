@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ── Auth page — dark immersive background ── */
    .auth-page {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 16px;
        position: relative;
        overflow: hidden;
        background: #0f0c1e;
        border-radius: 20px;
        margin: -28px -12px;
    }

    /* Floating bubbles */
    .auth-bubble {
        position: absolute;
        border-radius: 50%;
        background: rgba(124, 92, 248, .18);
        animation: authFloat linear infinite;
        pointer-events: none;
    }

    @@keyframes authFloat {
        0% {
            transform: translateY(0) scale(1);
            opacity: .7;
        }

        50% {
            opacity: .35;
        }

        100% {
            transform: translateY(-140px) scale(.4);
            opacity: 0;
        }
    }

    @@keyframes authFadeUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes authShimmer {
        0% {
            left: -100%;
        }

        100% {
            left: 200%;
        }
    }

    /* Card */
    .auth-card {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.10);
        border-radius: 22px;
        width: 100%;
        max-width: 400px;
        padding: 36px 32px 32px;
        position: relative;
        z-index: 2;
        animation: authFadeUp .5s cubic-bezier(.22,1,.36,1) both;
    }

    /* Brand */
    .auth-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        justify-content: center;
        margin-bottom: 28px;
        text-decoration: none;
    }

    .auth-brand-icon {
        width: 40px;
        height: 40px;
        border-radius: 11px;
        background: linear-gradient(135deg, #7c5cf8, #a78bfa);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .auth-brand-name {
        font-size: 17px;
        font-weight: 600;
        color: #fff;
        letter-spacing: -.2px;
    }

    .auth-card h2 {
        font-size: 20px;
        font-weight: 600;
        color: #fff;
        text-align: center;
        margin: 0 0 6px;
    }

    .auth-sub {
        font-size: 13px;
        color: rgba(255,255,255,.4);
        text-align: center;
        margin-bottom: 28px;
    }

    /* Alert */
    .auth-alert {
        background: rgba(220,38,38,.12);
        border: 1px solid rgba(220,38,38,.3);
        border-radius: 8px;
        padding: 9px 12px;
        font-size: 13px;
        color: #fca5a5;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        animation: authFadeUp .3s ease both;
    }

    .auth-alert-success {
        background: rgba(22,163,74,.12);
        border: 1px solid rgba(22,163,74,.3);
        color: #86efac;
    }

    /* Fields */
    .auth-field {
        margin-bottom: 16px;
    }

        .auth-field label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .07em;
            color: rgba(255,255,255,.38);
            margin-bottom: 7px;
        }

    .auth-field-wrap {
        position: relative;
    }

    .auth-field-icon {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,.28);
        font-size: 15px;
        pointer-events: none;
        transition: color .15s;
    }

    .auth-field input {
        width: 100%;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.10);
        border-radius: 10px;
        padding: 10px 12px 10px 38px;
        font-size: 14px;
        color: #fff;
        outline: none;
        transition: border-color .15s, background .15s;
        font-family: inherit;
    }

        .auth-field input::placeholder {
            color: rgba(255,255,255,.2);
        }

        .auth-field input:focus {
            border-color: rgba(124,92,248,.7);
            background: rgba(124,92,248,.08);
        }

            .auth-field input:focus + .auth-field-icon,
            .auth-field-wrap:focus-within .auth-field-icon {
                color: #a78bfa;
            }

    /* Submit button */
    .auth-btn {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 11px;
        background: linear-gradient(135deg, #7c5cf8, #9d7ffa);
        color: #fff;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 6px;
        position: relative;
        overflow: hidden;
        transition: opacity .15s;
        font-family: inherit;
    }

        .auth-btn:hover {
            opacity: .9;
        }

        .auth-btn::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 60%;
            height: 100%;
            background: rgba(255,255,255,.15);
            transform: skewX(-20deg);
            animation: authShimmer 2.4s ease-in-out infinite;
        }

    .auth-link-row {
        text-align: center;
        font-size: 13px;
        color: rgba(255,255,255,.32);
        margin-top: 20px;
    }

        .auth-link-row a {
            color: #a78bfa;
            text-decoration: none;
            font-weight: 500;
        }

            .auth-link-row a:hover {
                text-decoration: underline;
            }
</style>

<div class="auth-page" id="authPage">
    <div id="authBubbles"></div>

    <div class="auth-card">
        <a asp-controller="Home" asp-action="Index" class="auth-brand">
            <div class="auth-brand-icon">📖</div>
            <span class="auth-brand-name">Web Đọc Truyện</span>
        </a>

        <h2>Chào mừng trở lại</h2>
        <p class="auth-sub">Đăng nhập để tiếp tục đọc truyện</p>

        @if (TempData["Success"] != null)
        {
            <div class="auth-alert auth-alert-success">
                <i class="bi bi-check-circle"></i> @TempData["Success"]
            </div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="auth-alert" id="authError">
                <i class="bi bi-exclamation-circle"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="Login" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            @if (ViewBag.ReturnUrl != null)
            {
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            }

            <div class="auth-field">
                <label>Email</label>
                <div class="auth-field-wrap">
                    <i class="bi bi-envelope auth-field-icon"></i>
                    <input type="email" name="Email" required autocomplete="email" placeholder="ten@email.com" />
                </div>
            </div>

            <div class="auth-field">
                <label>Mật khẩu</label>
                <div class="auth-field-wrap">
                    <i class="bi bi-lock auth-field-icon"></i>
                    <input type="password" name="Password" required autocomplete="current-password" placeholder="••••••••" />
                </div>
            </div>

            <button type="submit" class="auth-btn">Đăng nhập</button>
        </form>

        <p class="auth-link-row">
            Chưa có tài khoản?
            <a asp-controller="Account" asp-action="Register">Đăng ký ngay</a>
        </p>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const pg = document.getElementById('authPage');
            const bw = document.getElementById('authBubbles');
            const cfg = [
                { s: 44, l: 8,  d: 7.0, delay: 0   },
                { s: 62, l: 22, d: 8.5, delay: 1.2 },
                { s: 30, l: 38, d: 6.2, delay: 0.5 },
                { s: 52, l: 54, d: 9.0, delay: 2.1 },
                { s: 70, l: 68, d: 7.8, delay: 0.9 },
                { s: 26, l: 80, d: 6.6, delay: 1.7 },
                { s: 48, l: 92, d: 8.2, delay: 0.3 },
            ];
            cfg.forEach(function (c) {
                var b = document.createElement('div');
                b.className = 'auth-bubble';
                b.style.cssText = 'width:' + c.s + 'px;height:' + c.s + 'px;left:' + c.l + '%;bottom:-' + c.s + 'px;animation-duration:' + c.d + 's;animation-delay:' + c.delay + 's';
                bw.appendChild(b);
            });

            var err = document.getElementById('authError');
            if (err) setTimeout(function () { err.style.opacity = '0'; err.style.transition = 'opacity .4s'; }, 4000);
        })();
    </script>
}
