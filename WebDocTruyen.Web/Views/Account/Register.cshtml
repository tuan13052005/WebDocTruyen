@{
    ViewData["Title"] = "Đăng ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .auth-page {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 16px;
        position: relative;
        overflow: hidden;
        background: #f8f7f5;
        border-radius: 20px;
        margin: -28px -12px;
    }

    .auth-bubble {
        position: absolute;
        border-radius: 50%;
        background: rgba(124, 58, 237, .12);
        animation: authFloat linear infinite;
        pointer-events: none;
    }

    @@keyframes authFloat {
        0% {
            transform: translateY(0);
            opacity: .5;
        }

        50% {
            opacity: .22;
        }

        100% {
            transform: translateY(-160px) scale(.3);
            opacity: 0;
        }
    }

    @@keyframes authFadeUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes authShimmer {
        0% {
            left: -100%;
        }

        100% {
            left: 220%;
        }
    }

    .auth-card {
        background: #fff;
        border: 1px solid #e8e6e3;
        border-radius: 18px;
        width: 100%;
        max-width: 400px;
        overflow: hidden;
        position: relative;
        z-index: 2;
        animation: authFadeUp .45s cubic-bezier(.22,1,.36,1) both;
    }

    .auth-card-header {
        background: linear-gradient(135deg, #1a0533, #2d1060);
        padding: 24px 24px 20px;
        position: relative;
        overflow: hidden;
    }

        .auth-card-header::after {
            content: '';
            position: absolute;
            top: -30px;
            right: -30px;
            width: 110px;
            height: 110px;
            background: radial-gradient(circle, rgba(236,72,153,.4) 0%, transparent 70%);
            pointer-events: none;
        }

    .auth-brand {
        display: flex;
        align-items: center;
        gap: 9px;
        margin-bottom: 14px;
        position: relative;
        z-index: 1;
        text-decoration: none;
    }

    .auth-brand-icon {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.18);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
    }

    .auth-brand-name {
        font-size: 14px;
        font-weight: 700;
        color: #fff;
    }

    .auth-card-title {
        font-size: 18px;
        font-weight: 800;
        color: #fff;
        position: relative;
        z-index: 1;
        margin-bottom: 4px;
    }

    .auth-card-sub {
        font-size: 11.5px;
        color: rgba(255,255,255,.5);
        position: relative;
        z-index: 1;
    }

    .auth-body {
        padding: 22px 22px 24px;
    }

    .auth-alert {
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 8px;
        padding: 9px 12px;
        font-size: 13px;
        color: #c0392b;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .auth-field {
        margin-bottom: 13px;
    }

        .auth-field label {
            display: block;
            font-size: 10.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: #6b7280;
            margin-bottom: 6px;
        }

    .auth-fw {
        position: relative;
    }

    .auth-fi {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        font-size: 15px;
        pointer-events: none;
        transition: color .15s;
    }

    .auth-field input {
        width: 100%;
        padding: 9px 12px 9px 34px;
        border: 1px solid #e8e6e3;
        border-radius: 9px;
        font-size: 13px;
        color: #1a1a1a;
        background: #fff;
        outline: none;
        transition: border-color .15s, box-shadow .15s;
        font-family: inherit;
    }

        .auth-field input::placeholder {
            color: #c9cdd5;
        }

        .auth-field input:focus {
            border-color: #7c3aed;
            box-shadow: 0 0 0 3px rgba(124,58,237,.10);
        }

    .auth-fw:focus-within .auth-fi {
        color: #7c3aed;
    }

    /* Strength bar */
    .pw-strength {
        margin-top: 6px;
        display: flex;
        align-items: center;
        gap: 8px;
        opacity: 0;
        transition: opacity .2s;
    }

    .pw-bar {
        flex: 1;
        height: 3px;
        background: #e8e6e3;
        border-radius: 3px;
        overflow: hidden;
    }

    .pw-fill {
        height: 100%;
        border-radius: 3px;
        width: 0;
        transition: width .3s, background .3s;
    }

    .pw-label {
        font-size: 11px;
        min-width: 56px;
        text-align: right;
    }

    .pw-match {
        font-size: 12px;
        margin-top: 5px;
        min-height: 16px;
    }

        .pw-match.ok {
            color: #16a34a;
        }

        .pw-match.err {
            color: #c0392b;
        }

    .auth-btn {
        width: 100%;
        padding: 11px;
        background: linear-gradient(135deg, #7c3aed, #ec4899);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        margin-top: 4px;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        font-family: inherit;
        transition: opacity .15s;
    }

        .auth-btn:hover {
            opacity: .9;
        }

        .auth-btn::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 55%;
            height: 100%;
            background: rgba(255,255,255,.18);
            transform: skewX(-20deg);
            animation: authShimmer 2.2s ease-in-out infinite;
        }

    .auth-link-row {
        text-align: center;
        font-size: 13px;
        color: #6b7280;
        margin-top: 16px;
    }

        .auth-link-row a {
            color: #7c3aed;
            text-decoration: none;
            font-weight: 600;
        }

            .auth-link-row a:hover {
                text-decoration: underline;
            }
</style>

<div class="auth-page">
    <div id="authBubbles"></div>

    <div class="auth-card">
        <div class="auth-card-header">
            <a asp-controller="Home" asp-action="Index" class="auth-brand">
                <div class="auth-brand-icon">📖</div>
                <span class="auth-brand-name">Web Đọc Truyện</span>
            </a>
            <div class="auth-card-title">Tạo tài khoản</div>
            <div class="auth-card-sub">Miễn phí, đọc không giới hạn</div>
        </div>

        <div class="auth-body">
            @if (ViewBag.Error != null)
            {
                <div class="auth-alert">
                    <i class="bi bi-exclamation-circle"></i> @ViewBag.Error
                </div>
            }

            <form asp-action="Register" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()

                <div class="auth-field">
                    <label>Tên đăng nhập</label>
                    <div class="auth-fw">
                        <i class="bi bi-person auth-fi"></i>
                        <input type="text" name="Username" required autocomplete="username" placeholder="Tên của bạn" />
                    </div>
                </div>

                <div class="auth-field">
                    <label>Email</label>
                    <div class="auth-fw">
                        <i class="bi bi-envelope auth-fi"></i>
                        <input type="email" name="Email" required autocomplete="email" placeholder="ten@email.com" />
                    </div>
                </div>

                <div class="auth-field">
                    <label>Mật khẩu</label>
                    <div class="auth-fw">
                        <i class="bi bi-lock auth-fi"></i>
                        <input type="password" name="Password" id="regPwd" required placeholder="Tối thiểu 6 ký tự" oninput="checkStrength(this.value)" />
                    </div>
                    <div class="pw-strength" id="strengthWrap">
                        <div class="pw-bar"><div class="pw-fill" id="pwFill"></div></div>
                        <span class="pw-label" id="pwLabel"></span>
                    </div>
                </div>

                <div class="auth-field">
                    <label>Xác nhận mật khẩu</label>
                    <div class="auth-fw">
                        <i class="bi bi-shield-check auth-fi"></i>
                        <input type="password" name="ConfirmPassword" id="regConfirm" required placeholder="Nhập lại mật khẩu" oninput="checkMatch()" />
                    </div>
                    <p class="pw-match" id="matchMsg"></p>
                </div>

                <button type="submit" class="auth-btn" id="regBtn">
                    <i class="bi bi-person-plus"></i> Tạo tài khoản
                </button>
            </form>

            <p class="auth-link-row">
                Đã có tài khoản?
                <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var bw = document.getElementById('authBubbles');
            [{s:60,l:5,d:8,dl:0},{s:35,l:20,d:6,dl:1.4},{s:80,l:38,d:10,dl:0.7},
             {s:45,l:55,d:7,dl:2.1},{s:65,l:70,d:8.5,dl:1},{s:28,l:83,d:5.5,dl:1.8},
             {s:50,l:92,d:7.5,dl:0.4}].forEach(function (c) {
                var b = document.createElement('div');
                b.className = 'auth-bubble';
                b.style.cssText = 'width:'+c.s+'px;height:'+c.s+'px;left:'+c.l+'%;bottom:-'+c.s+'px;animation-duration:'+c.d+'s;animation-delay:'+c.dl+'s';
                bw.appendChild(b);
            });
        })();

        function checkStrength(v) {
            var wrap = document.getElementById('strengthWrap');
            var fill = document.getElementById('pwFill');
            var lbl  = document.getElementById('pwLabel');
            if (!v) { wrap.style.opacity = '0'; return; }
            wrap.style.opacity = '1';
            var score = 0;
            if (v.length >= 6)  score++;
            if (v.length >= 10) score++;
            if (/[A-Z]/.test(v)) score++;
            if (/[0-9]/.test(v)) score++;
            if (/[^A-Za-z0-9]/.test(v)) score++;
            var levels = [
                { pct: '20%', color: '#ef4444', text: 'Rất yếu'    },
                { pct: '40%', color: '#f97316', text: 'Yếu'         },
                { pct: '60%', color: '#eab308', text: 'Trung bình'  },
                { pct: '80%', color: '#22c55e', text: 'Mạnh'        },
                { pct: '100%',color: '#16a34a', text: 'Rất mạnh'    },
            ];
            var lvl = levels[Math.max(0, score - 1)];
            fill.style.width      = lvl.pct;
            fill.style.background = lvl.color;
            lbl.textContent       = lvl.text;
            lbl.style.color       = lvl.color;
        }

        function checkMatch() {
            var pwd  = document.getElementById('regPwd').value;
            var conf = document.getElementById('regConfirm').value;
            var msg  = document.getElementById('matchMsg');
            var btn  = document.getElementById('regBtn');
            if (!conf) { msg.textContent = ''; return; }
            if (pwd === conf) {
                msg.textContent = '✓ Mật khẩu khớp';
                msg.className   = 'pw-match ok';
                btn.disabled    = false;
            } else {
                msg.textContent = '✗ Mật khẩu không khớp';
                msg.className   = 'pw-match err';
                btn.disabled    = true;
            }
        }
    </script>
}
