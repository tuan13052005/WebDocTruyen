@{
    ViewData["Title"] = "Đăng ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/login.css" />

<div class="auth-page">
    <div class="auth-blob auth-blob-1"></div>
    <div class="auth-blob auth-blob-2"></div>
    <div class="auth-blob auth-blob-3"></div>
    <div class="auth-halftone"></div>
    <div class="auth-slash auth-slash1"></div>
    <div class="auth-slash auth-slash2"></div>
    <div class="auth-slash auth-slash3"></div>
    <div id="authDoodles"></div>

    <div class="auth-card">

        <!-- Mascot peeking over the card -->
        <div class="auth-mascot" aria-hidden="true">
            <span class="mascot-face">(＾▽＾)</span>
            <span class="auth-mascot-spark s1">✦</span>
            <span class="auth-mascot-spark s2">✧</span>
        </div>

        <div class="auth-card-inner">
            <div class="auth-card-header">
                <div class="auth-burst"></div>
                <a asp-controller="Home" asp-action="Index" class="auth-brand">
                    <div class="auth-brand-icon">📖</div>
                    <span class="auth-brand-name">Web Đọc Truyện</span>
                </a>
                <div class="auth-card-title">
                    Tạo tài khoản <span class="wave">✨</span>
                </div>
                <div class="auth-card-sub">Miễn phí, đọc không giới hạn</div>
            </div>

            <div class="auth-body">
                @if (ViewBag.Error != null)
                {
                    <div class="auth-alert" id="authErr">
                        <i class="bi bi-exclamation-circle"></i> @ViewBag.Error
                    </div>
                }

                <form asp-action="Register" asp-controller="Account" method="post" id="registerForm">
                    @Html.AntiForgeryToken()

                    <div class="auth-field">
                        <label>Tên đăng nhập</label>
                        <div class="auth-fw">
                            <i class="bi bi-person auth-fi"></i>
                            <input type="text" name="Username" required autocomplete="username" placeholder="Tên của bạn" />
                        </div>
                    </div>

                    <div class="auth-field">
                        <label>Email</label>
                        <div class="auth-fw">
                            <i class="bi bi-envelope auth-fi"></i>
                            <input type="email" name="Email" required autocomplete="email" placeholder="ten@email.com" />
                        </div>
                    </div>

                    <div class="auth-field">
                        <label>Mật khẩu</label>
                        <div class="auth-fw">
                            <i class="bi bi-lock auth-fi"></i>
                            <input type="password" name="Password" id="regPwd" required autocomplete="new-password"
                                   placeholder="Tối thiểu 6 ký tự" oninput="checkStrength(this.value)" />
                        </div>
                        <div class="pw-strength" id="strengthWrap">
                            <div class="pw-bar"><div class="pw-fill" id="pwFill"></div></div>
                            <span class="pw-label" id="pwLabel"></span>
                        </div>
                    </div>

                    <div class="auth-field">
                        <label>Xác nhận mật khẩu</label>
                        <div class="auth-fw">
                            <i class="bi bi-shield-check auth-fi"></i>
                            <input type="password" name="ConfirmPassword" id="regConfirm" required autocomplete="new-password"
                                   placeholder="Nhập lại mật khẩu" oninput="checkMatch()" />
                        </div>
                        <p class="pw-match" id="matchMsg"></p>
                    </div>

                    <button type="submit" class="auth-btn" id="regBtn">
                        <i class="bi bi-person-plus btn-icon"></i> Tạo tài khoản
                    </button>
                </form>

                <p class="auth-link-row">
                    Đã có tài khoản?
                    <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            // ── Floating doodle stickers ──
            if (!reduceMotion) {
                var dw = document.getElementById('authDoodles');
                var doodles = [
                    { g: '✨', s: 20, l: 8,  t: 68, d: 8,  dl: 0 },
                    { g: '💫', s: 18, l: 88, t: 20, d: 9,  dl: .8 },
                    { g: '📚', s: 22, l: 15, t: 18, d: 10, dl: 1.4 },
                    { g: '💕', s: 16, l: 92, t: 62, d: 7.5, dl: .4 },
                    { g: '⭐', s: 15, l: 6,  t: 40, d: 8.5, dl: 1.9 }
                ];
                doodles.forEach(function (c) {
                    var el = document.createElement('span');
                    el.className = 'auth-doodle';
                    el.textContent = c.g;
                    el.style.cssText =
                        'font-size:' + c.s + 'px;left:' + c.l + '%;top:' + c.t + '%;' +
                        'animation-duration:' + c.d + 's, ' + (c.d * .8) + 's;' +
                        'animation-delay:' + c.dl + 's, ' + c.dl + 's;';
                    dw.appendChild(el);
                });
            }

            // ── Error alert auto-fade ──
            var err = document.getElementById('authErr');
            if (err) setTimeout(function () { err.style.transition = 'opacity .4s'; err.style.opacity = '0'; }, 4000);

            // ── Confetti burst on submit ──
            var btn = document.getElementById('regBtn');
            if (btn && !reduceMotion) {
                btn.addEventListener('click', function (e) {
                    var rect = btn.getBoundingClientRect();
                    var cx = rect.left + rect.width / 2;
                    var cy = rect.top + rect.height / 2;
                    var colors = ['#7c3aed', '#ec4899', '#fbbf24', '#67e8f9', '#a78bfa'];

                    for (var i = 0; i < 16; i++) {
                        var piece = document.createElement('span');
                        piece.className = 'auth-confetti-piece';
                        var angle = Math.random() * Math.PI * 2;
                        var dist = 60 + Math.random() * 70;
                        var ex = Math.cos(angle) * dist;
                        var ey = Math.sin(angle) * dist - 20;
                        piece.style.setProperty('--confetti-end', 'translate(' + ex + 'px,' + ey + 'px)');
                        piece.style.setProperty('--confetti-rot', (Math.random() * 480 - 240) + 'deg');
                        piece.style.left = cx + 'px';
                        piece.style.top = cy + 'px';
                        piece.style.width = (4 + Math.random() * 5) + 'px';
                        piece.style.height = (4 + Math.random() * 5) + 'px';
                        piece.style.background = colors[i % colors.length];
                        document.body.appendChild(piece);
                        (function (p) { setTimeout(function () { p.remove(); }, 820); })(piece);
                    }
                });
            }
        })();

        // ── Password strength ──
        function checkStrength(v) {
            var wrap = document.getElementById('strengthWrap');
            var fill = document.getElementById('pwFill');
            var lbl  = document.getElementById('pwLabel');
            if (!v) { wrap.style.opacity = '0'; return; }
            wrap.style.opacity = '1';
            var score = 0;
            if (v.length >= 6)  score++;
            if (v.length >= 10) score++;
            if (/[A-Z]/.test(v)) score++;
            if (/[0-9]/.test(v)) score++;
            if (/[^A-Za-z0-9]/.test(v)) score++;
            var levels = [
                { pct: '20%', color: '#ef4444', text: 'Rất yếu'    },
                { pct: '40%', color: '#f97316', text: 'Yếu'         },
                { pct: '60%', color: '#eab308', text: 'Trung bình'  },
                { pct: '80%', color: '#22c55e', text: 'Mạnh'        },
                { pct: '100%',color: '#16a34a', text: 'Rất mạnh'    },
            ];
            var lvl = levels[Math.max(0, score - 1)];
            fill.style.width      = lvl.pct;
            fill.style.background = lvl.color;
            lbl.textContent       = lvl.text;
            lbl.style.color       = lvl.color;
        }

        // ── Password match ──
        function checkMatch() {
            var pwd  = document.getElementById('regPwd').value;
            var conf = document.getElementById('regConfirm').value;
            var msg  = document.getElementById('matchMsg');
            var btn  = document.getElementById('regBtn');
            if (!conf) { msg.textContent = ''; return; }
            if (pwd === conf) {
                msg.textContent = '✓ Mật khẩu khớp';
                msg.className   = 'pw-match ok';
                btn.disabled    = false;
            } else {
                msg.textContent = '✗ Mật khẩu không khớp';
                msg.className   = 'pw-match err';
                btn.disabled    = true;
            }
        }
    </script>
}