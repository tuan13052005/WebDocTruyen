@model IEnumerable<WebDocTruyen.Application.DTOs.Story.StoryDto>
@{
    ViewData["Title"] = "Thể loại: " + ViewBag.GenreName;
    Layout = "~/Views/Shared/_Layout.cshtml";
    int cur = (int)(ViewBag.CurrentPage ?? 1);
    int total = (int)(ViewBag.TotalPages ?? 1);
    int items = (int)(ViewBag.TotalItems ?? 0);
    int size = (int)(ViewBag.PageSize ?? 12);
    int genreId = (int)(ViewBag.GenreId ?? 0);

    int ps = Math.Max(1, cur - 3);
    int pe = Math.Min(total, ps + 6);
    ps = Math.Max(1, pe - 6);
    string PageUrl(int p) => Url.Action("ByGenre", new { id = genreId })! + $"?pageSize={size}&page={p}";
}

<link rel="stylesheet" href="~/css/genres-byGenre.css" />

<div class="container bg-page">

    <!-- ══ HERO ══ -->
    <div class="bg-hero">
        <div class="bg-hero-bg"></div>
        <div class="bg-hero-dots"></div>
        <div class="bg-hero-glow"></div>
        <div class="bg-hero-orb1"></div>
        <div class="bg-hero-orb2"></div>
        <div class="bg-hero-slash"></div>

        <div class="bg-hero-inner">
            <div>
                <div class="bg-eyebrow">
                    <span class="bg-eyebrow-dot"></span>
                    Thể loại
                </div>
                <h1 class="bg-genre-title">🏷️ @ViewBag.GenreName</h1>
                <p class="bg-genre-sub">Khám phá tất cả truyện trong thể loại này</p>
            </div>

            <div class="bg-hero-right">
                <div class="bg-count-pill">
                    <span class="bg-count-num">@items</span>
                    <span class="bg-count-lbl">Bộ truyện</span>
                </div>
                <a asp-action="Index" asp-controller="Genres" class="bg-back-btn">
                    ← Tất cả thể loại
                </a>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <!-- ══ EMPTY ══ -->
        <div class="bg-empty">
            <div class="bg-empty-icon">📭</div>
            <h5>Chưa có truyện nào</h5>
            <p>Thể loại này chưa được cập nhật truyện. Hãy quay lại sau!</p>
            <a asp-controller="Story" asp-action="Index" class="bg-empty-btn">
                <i class="bi bi-compass-fill"></i> Khám phá thể loại khác
            </a>
        </div>
    }
    else
    {
        <!-- ══ TOOLBAR ══ -->
        <div class="bg-toolbar">
            <div class="bg-toolbar-left">
                <div class="bg-accent-bar"></div>
                <span class="bg-section-title">Danh sách truyện</span>
                <span class="bg-count-badge">@items truyện</span>
            </div>
            <div class="bg-page-select">
                <span>Hiển thị</span>
                <select onchange="location.href='@(Url.Action("ByGenre", new { id = genreId }))' + '?pageSize=' + this.value + '&page=1'">
                    @foreach (var s in new[] { 12, 24, 48 })
                    {
                        if (size == s)
                        {
                            <option value="@s" selected>@s / trang</option>
                        }
                        else
                        {
                            <option value="@s">@s / trang</option>
                        }
                    }
                </select>
            </div>
        </div>

        <!-- ══ GRID ══ -->
        <div class="bg-grid">
            @foreach (var s in Model)
            {
                <div class="bg-card">
                    <div class="bg-thumb">
                        <img src="@s.CoverImage"
                             alt="@s.Title"
                             loading="lazy"
                             onerror="this.src='/images/default.jpg'" />
                        <div class="bg-thumb-overlay"></div>

                        @if (s.Status == "completed")
                        {
                            <span class="bg-status bg-status-done">✅ Xong</span>
                        }
                        else
                        {
                            <span class="bg-status bg-status-ongoing">🔄 Đang ra</span>
                        }

                        <span class="bg-chap">
                            <i class="bi bi-collection" style="font-size:9px;"></i>
                            @s.ChapterCount ch.
                        </span>

                        @if (s.AvgRating > 0)
                        {
                            <span class="bg-rating">★ @s.AvgRating.ToString("F1")</span>
                        }
                    </div>

                    <div class="bg-body">
                        <a asp-action="Details" asp-controller="Story"
                           asp-route-id="@s.Id"
                           class="bg-card-title"
                           title="@s.Title">@s.Title</a>
                        <p class="bg-card-author">
                            <i class="bi bi-person" style="font-size:10px;"></i>
                            @s.Author
                        </p>
                        <a asp-action="Details" asp-controller="Story"
                           asp-route-id="@s.Id"
                           class="bg-card-btn">
                            Đọc ngay →
                        </a>
                    </div>
                </div>
            }
        </div>

        <!-- ══ PAGINATION ══ -->
        @if (total > 1)
        {
            <div class="bg-pagination">
                <div class="bg-page-nav">
                    <a class="bg-page-btn @(cur == 1 ? "is-disabled" : "")" href="@PageUrl(1)">«</a>
                    <a class="bg-page-btn @(cur == 1 ? "is-disabled" : "")" href="@PageUrl(cur - 1)">‹</a>

                    @for (int p = ps; p <= pe; p++)
                    {
                        <a class="bg-page-btn @(p == cur ? "is-active" : "")" href="@PageUrl(p)">@p</a>
                    }

                    <a class="bg-page-btn @(cur == total ? "is-disabled" : "")" href="@PageUrl(cur + 1)">›</a>
                    <a class="bg-page-btn @(cur == total ? "is-disabled" : "")" href="@PageUrl(total)">»</a>
                </div>
                <p class="bg-page-info">Trang @cur / @total &nbsp;·&nbsp; @items truyện</p>
            </div>
        }
    }
</div>
