@model WebDocTruyen.Application.DTOs.Genre.GenreDto
@{
    ViewData["Title"] = "Sửa thể loại";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/genres-edit.css" />

<div class="ge-page">
    <div class="ge-card">

        <!-- ── Header ── -->
        <div class="ge-header">
            <div class="ge-glow-bar"></div>
            <div class="ge-orb ge-orb-1"></div>
            <div class="ge-orb ge-orb-2"></div>
            <div class="ge-orb ge-orb-3"></div>

            <div class="ge-header-inner">
                <div class="ge-header-icon">✏️</div>
                <div class="ge-header-text">
                    <div class="ge-eyebrow">
                        <span class="ge-eyebrow-dot"></span>
                        Quản lý thể loại
                    </div>
                    <h1 class="ge-title">Chỉnh sửa thể loại</h1>
                    <p class="ge-sub">Cập nhật tên và mô tả của thể loại</p>
                </div>
            </div>

            <div class="ge-name-chip">
                <i class="bi bi-tag-fill"></i>
                Đang sửa: @Model.Name
            </div>
        </div>

        <!-- ── Form body ── -->
        <form asp-action="Edit" method="post" id="geForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="GenreId" />

            <div class="ge-body">
                <div class="ge-section-lbl">Thông tin thể loại</div>

                <!-- Tên -->
                <div class="ge-field">
                    <label class="ge-label">
                        <i class="bi bi-tag"></i>
                        Tên thể loại
                        <span class="ge-required">*</span>
                    </label>
                    <div class="ge-input-wrap">
                        <i class="bi bi-type ge-input-icon"></i>
                        <input asp-for="Name"
                               class="ge-input"
                               placeholder="VD: Hành động, Tình cảm, Isekai..."
                               required
                               id="nameInput"
                               maxlength="50" />
                    </div>
                    <span asp-validation-for="Name" class="ge-validation"></span>
                </div>

                <!-- Mô tả -->
                <div class="ge-field">
                    <label class="ge-label">
                        <i class="bi bi-card-text"></i>
                        Mô tả
                        <span class="ge-optional">Tuỳ chọn</span>
                    </label>
                    <div class="ge-textarea-wrap">
                        <i class="bi bi-pencil-square ge-textarea-icon"></i>
                        <textarea asp-for="Description"
                                  class="ge-textarea"
                                  placeholder="Mô tả ngắn về thể loại này..."
                                  maxlength="300"
                                  id="descInput"
                                  oninput="updateCount()"></textarea>
                    </div>
                    <div class="ge-char-count">
                        <span id="charCount">0</span> / 300
                    </div>
                </div>
            </div>

            <!-- ── Footer ── -->
            <div class="ge-actions">
                <a asp-action="Index" class="ge-btn-back">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
                <button type="submit" class="ge-btn-submit">
                    <span>
                        <i class="bi bi-floppy-fill"></i>
                        Lưu thay đổi
                    </span>
                </button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    <script>
        // Char counter
        function updateCount() {
            const len = document.getElementById('descInput').value.length;
            const el  = document.getElementById('charCount');
            el.textContent = len;
            el.style.color = len > 260 ? '#ec4899' : '';
        }
        // Init on load
        updateCount();

        // Subtle input focus ring lift
        document.querySelectorAll('.ge-input, .ge-textarea').forEach(el => {
            el.addEventListener('focus', () => {
                el.closest('.ge-field').style.transform = 'translateY(-1px)';
                el.closest('.ge-field').style.transition = 'transform .2s';
            });
            el.addEventListener('blur', () => {
                el.closest('.ge-field').style.transform = '';
            });
        });
    </script>
}
