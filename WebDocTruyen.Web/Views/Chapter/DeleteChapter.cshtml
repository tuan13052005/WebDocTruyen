@model WebDocTruyen.Application.DTOs.Chapter.ChapterDeleteDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Xác nhận xóa Chapter";
}

<div class="container mt-4" style="max-width:500px;">
    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            🗑️ Xác nhận xóa Chapter @Model.ChapterNumber
        </div>
        <div class="card-body">
            <p>Bạn có chắc muốn xóa chapter sau không?</p>
            <ul class="list-unstyled">
                <li><strong>Số chapter:</strong> @Model.ChapterNumber</li>
                <li><strong>Tiêu đề:</strong> @(string.IsNullOrEmpty(Model.Title) ? "(không có)" : Model.Title)</li>
                <li>
                    <strong>Số ảnh:</strong>
                    <span class="badge bg-warning text-dark">@Model.ImageCount ảnh sẽ bị xóa vĩnh viễn</span>
                </li>
            </ul>
            <p class="text-danger fw-semibold">⚠️ Hành động này không thể hoàn tác!</p>

            <form asp-action="DeleteChapter" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.ChapterId" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
                    <a asp-action="ListChapters" asp-controller="Chapter"
                       asp-route-id="@Model.StoryId"
                       class="btn btn-secondary">Huỷ</a>
                </div>
            </form>
        </div>
    </div>
</div>
