@model WebDocTruyen.Application.DTOs.Chapter.ChapterManageDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = $"Quản lý ảnh — Chapter {Model.ChapterNumber}";

    // Dữ liệu từ ViewBag (truyền từ controller)
    var otherChapters = ViewBag.OtherChapters as List<WebDocTruyen.Application.DTOs.Chapter.ChapterSummaryDto>
                         ?? new List<WebDocTruyen.Application.DTOs.Chapter.ChapterSummaryDto>();
    var recentImages = ViewBag.RecentImages as List<WebDocTruyen.Application.DTOs.Chapter.ChapterImageDto>
                         ?? new List<WebDocTruyen.Application.DTOs.Chapter.ChapterImageDto>();
    int totalChapters = (int)(ViewBag.TotalChapters ?? 0);
    int totalStoryImgs = (int)(ViewBag.TotalStoryImages ?? 0);
}

<link rel="stylesheet" href="~/css/ManageImages-Chapters.css" />

<!-- Breadcrumb-->
<nav class="mi-breadcrumb" aria-label="breadcrumb">
    <a asp-controller="Story" asp-action="Index">Danh sách truyện</a>
    <span class="mi-breadcrumb-sep">/</span>
    <a asp-controller="Story" asp-action="Details" asp-route-id="@Model.StoryId">@Model.StoryTitle</a>
    <span class="mi-breadcrumb-sep">/</span>
    <a asp-controller="Chapter" asp-action="ListChapters" asp-route-id="@Model.StoryId">Danh sách chapter</a>
    <span class="mi-breadcrumb-sep">/</span>
    <span class="mi-breadcrumb-cur">Chapter @Model.ChapterNumber — Quản lý ảnh</span>
</nav>

<!-- Header-->
<div class="mi-header">
    <div class="mi-header-left">
        <h2>🖼️ Quản lý ảnh — Chapter @Model.ChapterNumber</h2>
        @if (!string.IsNullOrEmpty(Model.Title))
        {
            <p>@Model.Title</p>
        }
    </div>
    <div class="mi-header-right">
        <span class="mi-count-badge">
            <i class="bi bi-images"></i> @Model.Images.Count trang
        </span>
        @if (Model.Images.Any())
        {
            <form asp-action="DeleteAllImages" method="post" class="d-inline"
                  onsubmit="return confirm('Xóa toàn bộ @Model.Images.Count ảnh trong chapter này?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="chapterId" value="@Model.ChapterId" />
                <button type="submit" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash3"></i> Xóa tất cả
                </button>
            </form>
        }
    </div>
</div>

<!-- Main layout: 2 cột-->
<div class="mi-layout">

    <!-- ── Cột trái: upload + grid ảnh ──-->
    <div>

        <!-- Upload card-->
        <div class="mi-upload-card">
            <div class="mi-upload-hd">
                <i class="bi bi-cloud-upload"></i> Upload ảnh mới
            </div>
            <div class="mi-upload-body">
                <form asp-action="UploadImages" method="post" enctype="multipart/form-data" id="uploadForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="chapterId" value="@Model.ChapterId" />

                    <div class="mi-dropzone" id="dropZone">
                        <input type="file" name="imageFiles" id="imageInput"
                               multiple accept=".jpg,.jpeg,.png,.gif,.webp" />
                        <div class="mi-dropzone-icon"><i class="bi bi-cloud-arrow-up"></i></div>
                        <div class="mi-dropzone-text">Kéo thả ảnh vào đây hoặc bấm để chọn</div>
                        <div class="mi-dropzone-hint">JPG · PNG · GIF · WEBP · Tối đa 10 MB / ảnh</div>
                    </div>

                    <div class="mi-preview-area" id="previewArea"></div>

                    <div class="mi-upload-footer">
                        <button type="submit" class="mi-btn-upload" id="uploadBtn" disabled>
                            <i class="bi bi-cloud-upload"></i>
                            Upload <span id="fileCountLabel">0</span> ảnh
                        </button>
                        <span class="mi-file-count" id="fileSizeInfo"></span>
                    </div>
                </form>
            </div>
        </div>

        <!-- Grid ảnh-->
        @if (!Model.Images.Any())
        {
            <div class="mi-empty">
                <div class="mi-empty-icon">🖼️</div>
                <p class="fw-semibold mb-1">Chapter này chưa có ảnh nào</p>
                <p class="small mb-0">Hãy upload ảnh ở phía trên để bắt đầu.</p>
            </div>
        }
        else
        {
            <div class="mi-grid-hd">
                <div class="mi-grid-title">
                    <div class="mi-grid-bar"></div>
                    📋 Danh sách trang
                    <span style="font-size:12px;font-weight:400;color:#9ca3af;">(@Model.Images.Count ảnh)</span>
                </div>
                <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                    <span class="mi-grid-hint">
                        <i class="bi bi-grip-vertical"></i> Kéo thả để sắp xếp
                    </span>
                    <button class="mi-save-order-btn" id="saveOrderBtn">
                        <i class="bi bi-floppy"></i> Lưu thứ tự
                    </button>
                </div>
            </div>

            <div class="mi-grid" id="imageGrid">
                @foreach (var img in Model.Images)
                {
                    <div class="mi-img-item" data-id="@img.ImageId">
                        <span class="mi-page-badge" data-page>Trang @img.PageNumber</span>
                        <div class="mi-drag-handle" title="Kéo để sắp xếp">
                            <i class="bi bi-grip-vertical"></i>
                        </div>
                        <img src="@img.ImageUrl"
                             alt="Trang @img.PageNumber"
                             loading="lazy"
                             onclick="openLightbox('@img.ImageUrl', @img.PageNumber)"
                             title="Bấm để xem lớn" />
                        <div class="mi-img-footer">
                            <form asp-action="DeleteImage" method="post"
                                  onsubmit="return confirm('Xóa trang @img.PageNumber?');"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="imageId" value="@img.ImageId" />
                                <input type="hidden" name="chapterId" value="@Model.ChapterId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2"
                                        title="Xóa ảnh này">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Điều hướng dưới-->
        <div class="mi-footer-actions">
            <a asp-action="ListChapters" asp-controller="Chapter" asp-route-id="@Model.StoryId"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i> Về danh sách chapter
            </a>
            <a asp-action="EditChapter" asp-controller="Chapter" asp-route-id="@Model.ChapterId"
               class="btn btn-outline-primary btn-sm">
                <i class="bi bi-pencil me-1"></i> Sửa thông tin chapter
            </a>
            <a asp-action="Details" asp-controller="Story" asp-route-id="@Model.StoryId"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-book me-1"></i> Trang truyện
            </a>
        </div>
    </div>

    <!-- ── Cột phải: sidebar ──-->
    <aside class="mi-sidebar">

        <!-- Widget thống kê chapter này-->
        <div class="mi-widget">
            <div class="mi-widget-hd purple">
                <i class="bi bi-bar-chart-fill"></i> Thống kê chapter
            </div>
            <div class="mi-stats-grid">
                <div class="mi-stat">
                    <div class="mi-stat-num">@Model.Images.Count</div>
                    <div class="mi-stat-lbl">Trang ảnh</div>
                </div>
                <div class="mi-stat">
                    <div class="mi-stat-num">@totalChapters</div>
                    <div class="mi-stat-lbl">Tổng chapter</div>
                </div>
                <div class="mi-stat">
                    <div class="mi-stat-num">@totalStoryImgs</div>
                    <div class="mi-stat-lbl">Ảnh truyện</div>
                </div>
                <div class="mi-stat">
                    <div class="mi-stat-num">@Model.ChapterNumber</div>
                    <div class="mi-stat-lbl">Số chapter</div>
                </div>
            </div>
        </div>
<!-- Lightbox-->
<div class="mi-lightbox" id="lightbox" onclick="closeLightbox()">
    <div class="mi-lightbox-inner">
        <img class="mi-lightbox-img" id="lightboxImg" src="" alt="" />
        <p class="mi-lightbox-caption" id="lightboxCaption"></p>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <script>
        // ── Upload: preview & đếm file ─────────────────────────────────
        const imageInput    = document.getElementById('imageInput');
        const previewArea   = document.getElementById('previewArea');
        const uploadBtn     = document.getElementById('uploadBtn');
        const fileCountLbl  = document.getElementById('fileCountLabel');
        const fileSizeInfo  = document.getElementById('fileSizeInfo');
        const dropZone      = document.getElementById('dropZone');

        function renderPreviews(files) {
        previewArea.innerHTML = '';
        let totalSize = 0;
        files.forEach(f => {
        totalSize += f.size;
        const reader = new FileReader();
        reader.onload = e => {
        const div = document.createElement('div');
        div.className = 'mi-preview-thumb';
        div.innerHTML = `
        <img src="${e.target.result}" alt="${f.name}" />
        <div class="mi-preview-name">${f.name}</div>`;
        previewArea.appendChild(div);
        };
        reader.readAsDataURL(f);
        });
        fileCountLbl.textContent = files.length;
        uploadBtn.disabled = files.length === 0;
        fileSizeInfo.textContent = files.length > 0
        ? `Tổng: ${(totalSize / 1024 / 1024).toFixed(1)} MB`
        : '';
        }

        imageInput.addEventListener('change', function () {
        renderPreviews(Array.from(this.files));
        });

        // Drag-and-drop vào dropzone
        dropZone.addEventListener('dragover',  e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
        dropZone.addEventListener('drop', e => {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
        const dt = new DataTransfer();
        Array.from(e.dataTransfer.files)
        .filter(f => /\.(jpe?g|png|gif|webp)$/i.test(f.name))
        .forEach(f => dt.items.add(f));
        imageInput.files = dt.files;
        renderPreviews(Array.from(dt.files));
        });

        // ── Sortable drag-and-drop sắp xếp ảnh ────────────────────────
        const grid = document.getElementById('imageGrid');
        if (grid) {
        Sortable.create(grid, {
        animation: 220,
        easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
        handle: '.mi-drag-handle',
        ghostClass: 'sortable-ghost',
        chosenClass: 'sortable-chosen',
        dragClass: 'sortable-drag',
        forceFallback: true,
        fallbackTolerance: 3,
        swapThreshold: 0.65,
        onEnd: function () {
        // Cập nhật số trang hiển thị
        grid.querySelectorAll('.mi-img-item').forEach((el, idx) => {
        el.querySelector('[data-page]').textContent = `Trang ${idx + 1}`;
        });
        document.getElementById('saveOrderBtn').classList.add('visible');
        }
        });
        }

        // ── Lưu thứ tự ảnh ────────────────────────────────────────────
        document.getElementById('saveOrderBtn')?.addEventListener('click', async function () {
        const ids = Array.from(grid.querySelectorAll('.mi-img-item'))
        .map(el => parseInt(el.dataset.id));
        this.disabled = true;
        this.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lưu…';

        try {
        const token = document.querySelector('input[name=__RequestVerificationToken]')?.value ?? '';
        const resp = await fetch('@Url.Action("ReorderImages", "Chapter")', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json',
        'RequestVerificationToken': token
        },
        body: JSON.stringify({ imageIds: ids })
        });
        const data = await resp.json();
        if (data.success) {
        this.innerHTML = '<i class="bi bi-check-lg"></i> Đã lưu!';
        this.style.background = 'linear-gradient(135deg,#059669,#34d399)';
        setTimeout(() => {
        this.innerHTML = '<i class="bi bi-floppy"></i> Lưu thứ tự';
        this.style.background = '';
        this.disabled = false;
        this.classList.remove('visible');
        }, 2000);
        } else {
        throw new Error('failed');
        }
        } catch {
        this.innerHTML = '<i class="bi bi-x-circle"></i> Lỗi, thử lại';
        this.style.background = 'linear-gradient(135deg,#dc2626,#f87171)';
        this.disabled = false;
        }
        });

        // ── Lightbox ───────────────────────────────────────────────────
        const lightbox = document.getElementById('lightbox');

        function openLightbox(url, page) {
        document.getElementById('lightboxImg').src = url;
        document.getElementById('lightboxCaption').textContent = `Trang ${page}`;
        lightbox.classList.add('open');
        document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
        lightbox.classList.remove('open');
        document.getElementById('lightboxImg').src = '';
        document.body.style.overflow = '';
        }

        document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeLightbox();
        });
    </script>

    @Html.AntiForgeryToken()
}
