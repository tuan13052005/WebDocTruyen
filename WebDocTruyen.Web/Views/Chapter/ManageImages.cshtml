@model WebDocTruyen.Application.DTOs.Chapter.ChapterManageDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = $"Quản lý ảnh - Chapter {Model.ChapterNumber}";
}

<div class="container mt-4">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Story" asp-action="Index">Truyện</a></li>
            <li class="breadcrumb-item">
                <a asp-controller="Chapter" asp-action="ListChapters" asp-route-id="@Model.StoryId">@Model.StoryTitle</a>
            </li>
            <li class="breadcrumb-item active">Chapter @Model.ChapterNumber</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">🖼️ Quản lý ảnh — Chapter @Model.ChapterNumber</h3>
            @if (!string.IsNullOrEmpty(Model.Title))
            {
                <p class="text-muted mb-0">@Model.Title</p>
            }
        </div>
        <div class="d-flex gap-2">
            <span class="badge bg-secondary fs-6">@Model.Images.Count trang</span>
            @if (Model.Images.Any())
            {
                <form asp-action="DeleteAllImages" method="post" class="d-inline"
                      onsubmit="return confirm('Xóa toàn bộ @Model.Images.Count ảnh?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="chapterId" value="@Model.ChapterId" />
                    <button type="submit" class="btn btn-outline-danger btn-sm">🗑️ Xóa tất cả</button>
                </form>
            }
        </div>
    </div>

    <!-- ── Upload ảnh ─────────────────────────────────────────────────── -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-success text-white fw-semibold">⬆️ Upload ảnh mới</div>
        <div class="card-body">
            <form asp-action="UploadImages" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="chapterId" value="@Model.ChapterId" />

                <div class="mb-3">
                    <label class="form-label">Chọn ảnh <span class="text-muted small">(jpg/png/gif/webp, tối đa 10MB mỗi ảnh, có thể chọn nhiều)</span></label>
                    <input type="file" name="imageFiles" class="form-control" multiple
                           accept=".jpg,.jpeg,.png,.gif,.webp" id="imageInput" />
                </div>

                <div id="previewArea" class="d-flex flex-wrap gap-2 mb-3"></div>

                <button type="submit" class="btn btn-success" id="uploadBtn" disabled>
                    ⬆️ Upload (<span id="fileCount">0</span> ảnh)
                </button>
            </form>
        </div>
    </div>

    <!-- ── Danh sách ảnh ─────────────────────────────────────────────── -->
    @if (!Model.Images.Any())
    {
        <div class="alert alert-info">Chapter này chưa có ảnh nào. Hãy upload ảnh phía trên!</div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="mb-0">📋 Danh sách trang (@Model.Images.Count ảnh)</h5>
            <div class="d-flex gap-2 align-items-center">
                <span class="text-muted small"><i class="bi bi-grip-vertical"></i> Kéo thả để sắp xếp lại thứ tự</span>
                <button id="saveOrderBtn" class="btn btn-primary btn-sm d-none">💾 Lưu thứ tự</button>
            </div>
        </div>

        <div id="imageGrid" class="row row-cols-2 row-cols-md-4 row-cols-lg-6 g-3 mb-4">
            @foreach (var img in Model.Images)
            {
                <div class="col image-item" data-id="@img.ImageId">
                    <div class="card h-100 shadow-sm position-relative">
                        <span class="badge bg-dark position-absolute top-0 start-0 m-1 page-badge" style="z-index:3;">Trang @img.PageNumber</span>
                        <div class="drag-handle position-absolute top-0 end-0 m-1 text-white"
                             style="cursor:grab; background:rgba(0,0,0,.6); border-radius:4px; padding:2px 5px; z-index:3;">
                            <i class="bi bi-grip-vertical"></i>
                        </div>
                        <img src="@img.ImageUrl" class="card-img-top"
                             alt="Trang @img.PageNumber"
                             style="height:180px; object-fit:contain; background:#f8f9fa; cursor:pointer; position:relative; z-index:1;"
                             onclick="openLightbox('@img.ImageUrl', @img.PageNumber)" />
                        <div class="card-footer p-1 d-flex gap-1 justify-content-center">
                            <form asp-action="DeleteImage" method="post"
                                  onsubmit="return confirm('Xóa trang @img.PageNumber?');" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="imageId" value="@img.ImageId" />
                                <button type="submit" class="btn btn-danger btn-sm" title="Xóa trang này">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="d-flex gap-2 mt-3">
        <a asp-action="ListChapters" asp-controller="Chapter" asp-route-id="@Model.StoryId"
           class="btn btn-outline-secondary">← Về danh sách chapter</a>
        <a asp-action="EditChapter" asp-route-id="@Model.ChapterId"
           class="btn btn-outline-primary">✏️ Sửa thông tin chapter</a>
    </div>
</div>

<div id="lightbox" class="d-none position-fixed top-0 start-0 w-100 h-100"
     style="background:rgba(0,0,0,.85); z-index:9999; cursor:zoom-out;" onclick="closeLightbox()">
    <div class="d-flex align-items-center justify-content-center h-100">
        <div class="text-center">
            <img id="lightboxImg" src="" style="max-height:90vh; max-width:90vw; border-radius:4px;" />
            <p id="lightboxCaption" class="text-white mt-2 fs-5"></p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <script>
        document.getElementById('imageInput').addEventListener('change', function () {
            const files = Array.from(this.files);
            const preview = document.getElementById('previewArea');
            const btn = document.getElementById('uploadBtn');
            const countSpan = document.getElementById('fileCount');
            preview.innerHTML = '';
            files.forEach(f => {
                const reader = new FileReader();
                reader.onload = e => {
                    const div = document.createElement('div');
                    div.style.cssText = 'position:relative;';
                    div.innerHTML = `
                        <img src="${e.target.result}" style="width:80px;height:80px;object-fit:cover;border-radius:6px;border:2px solid #dee2e6;" />
                        <small class="d-block text-center text-muted" style="width:80px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">${f.name}</small>`;
                    preview.appendChild(div);
                };
                reader.readAsDataURL(f);
            });
            countSpan.textContent = files.length;
            btn.disabled = files.length === 0;
        });

        const grid = document.getElementById('imageGrid');
        if (grid) {
            Sortable.create(grid, {
                animation: 200,
                easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
                ghostClass: 'sortable-ghost',
                chosenClass: 'sortable-chosen',
                dragClass: 'sortable-drag',
                handle: '.drag-handle',
                forceFallback: true,
                fallbackTolerance: 0,
                fallbackOnBody: true,
                fallbackOffset: { x: 0, y: 0 },
                swapThreshold: 0.65,
                invertSwap: true,
                dragoverBubble: false,
                onEnd: function () {
                    document.getElementById('saveOrderBtn').classList.remove('d-none');
                    grid.querySelectorAll('.image-item').forEach((el, idx) => {
                        el.querySelector('.page-badge').textContent = `Trang ${idx + 1}`;
                    });
                }
            });
        }

        document.getElementById('saveOrderBtn')?.addEventListener('click', async function () {
            const ids = Array.from(grid.querySelectorAll('.image-item')).map(el => parseInt(el.dataset.id));
            this.disabled = true; this.textContent = '⏳ Đang lưu...';
            try {
                const resp = await fetch('@Url.Action("ReorderImages", "Chapter")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name=__RequestVerificationToken]')?.value ?? '' },
                    body: JSON.stringify({ imageIds: ids })
                });
                const data = await resp.json();
                if (data.success) {
                    this.textContent = '✅ Đã lưu!'; this.classList.replace('btn-primary', 'btn-success');
                    setTimeout(() => { this.classList.replace('btn-success', 'btn-primary'); this.textContent = '💾 Lưu thứ tự'; this.disabled = false; }, 2000);
                }
            } catch { this.textContent = '❌ Lỗi, thử lại'; this.disabled = false; }
        });

        function openLightbox(url, page) {
            document.getElementById('lightboxImg').src = url;
            document.getElementById('lightboxCaption').textContent = `Trang ${page}`;
            document.getElementById('lightbox').classList.remove('d-none');
        }
        function closeLightbox() { document.getElementById('lightbox').classList.add('d-none'); }
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
    </script>
    <style>
        .image-item {
            transition: transform .25s cubic-bezier(0.22, 1, 0.36, 1);
        }

            .image-item .card {
                transition: box-shadow .15s ease, transform .15s ease;
            }

        .sortable-ghost {
            opacity: .35;
        }

            .sortable-ghost .card {
                box-shadow: none !important;
                border: 2px dashed #0d6efd;
            }

        .sortable-chosen .card {
            box-shadow: 0 0 0 3px #0d6efd !important;
        }
        .sortable-drag .card,
        .sortable-fallback-clone .card {
            box-shadow: 0 10px 24px rgba(0,0,0,.30) !important;
            cursor: grabbing !important;
        }

        .sortable-drag, .sortable-fallback-clone {
            transition: none !important;
        }

        .image-item .card:hover {
            box-shadow: 0 0 0 3px #0d6efd66 !important;
        }

        #imageGrid.sortable-fallback,
        #imageGrid .image-item {
            user-select: none;
            -webkit-user-drag: none;
        }
    </style>
    @Html.AntiForgeryToken()
}