@model WebDocTruyen.Domain.Entities.Chapter
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Thêm Chapter";
    var story = ViewBag.Story as WebDocTruyen.Domain.Entities.Story;
}

<div class="container mt-4" style="max-width:600px;">
    <h2>➕ Thêm Chapter mới</h2>
    @if (story != null)
    {
        <p class="text-muted">Truyện: <strong>@story.Title</strong></p>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@err.ErrorMessage</div>
            }
        </div>
    }

    <form asp-action="AddChapter" asp-controller="Chapter" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="storyId" value="@story?.StoryId" />

        <div class="mb-3">
            <label class="form-label">Số Chapter <span class="text-danger">*</span></label>
            <input asp-for="ChapterNumber" class="form-control" type="number" min="1" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Tiêu đề</label>
            <input asp-for="Title" class="form-control" placeholder="VD: Khởi đầu..." />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Lưu Chapter</button>
            <a asp-action="ListChapters" asp-controller="Chapter" asp-route-id="@story?.StoryId"
               class="btn btn-secondary">← Quay lại</a>
        </div>
    </form>
</div>