@model WebDocTruyen.Application.DTOs.Chapter.ChapterFormDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Sửa Chapter";
    var story = ViewBag.Story as WebDocTruyen.Domain.Entities.Story;
}

<div class="container mt-4" style="max-width:560px;">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            @if (story != null)
            {
                <li class="breadcrumb-item">
                    <a asp-action="ListChapters" asp-controller="Chapter" asp-route-id="@story.StoryId">
                        @story.Title
                    </a>
                </li>
            }
            <li class="breadcrumb-item active">Sửa Chapter @Model.ChapterNumber</li>
        </ol>
    </nav>

    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark fw-semibold">
            ✏️ Sửa thông tin Chapter @Model.ChapterNumber
        </div>
        <div class="card-body">
            <form asp-action="EditChapter" asp-controller="Chapter" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ChapterId" />
                <input type="hidden" asp-for="StoryId" />

                <div class="mb-3">
                    <label asp-for="ChapterNumber" class="form-label">Số Chapter <span class="text-danger">*</span></label>
                    <input asp-for="ChapterNumber" class="form-control" type="number" min="1" required />
                    <span asp-validation-for="ChapterNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Tiêu đề</label>
                    <input asp-for="Title" class="form-control" placeholder="VD: Khởi đầu mới..." />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">💾 Cập nhật</button>
                    <!-- FIX: asp-action="List" → asp-action="ListChapters" -->
                    <a asp-action="ManageImages" asp-route-chapterId="@Model.ChapterId"
                       class="btn btn-outline-info">🖼️ Quản lý ảnh</a>
                    <a asp-action="ListChapters" asp-controller="Chapter"
                       asp-route-id="@Model.StoryId"
                       class="btn btn-outline-secondary">← Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>