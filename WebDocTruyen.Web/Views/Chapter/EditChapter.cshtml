@model WebDocTruyen.Application.DTOs.Chapter.ChapterFormDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Sửa Chapter";
    var story = ViewBag.Story as WebDocTruyen.Domain.Entities.Story;
}

<link rel="stylesheet" href="~/css/Edit-Chapter.css" />

<div class="ec-wrap">

    <!-- ── Hero ── -->
    <div class="ec-hero">
        <div class="ec-hero-icon">
            <i class="bi bi-pencil-square"></i>
        </div>
        <div class="ec-hero-meta">
            <h1 class="ec-hero-title">Sửa Chapter @Model.ChapterNumber</h1>
            @if (story != null)
            {
                <p class="ec-hero-sub">
                    <i class="bi bi-book"></i> @story.Title
                </p>
            }
            else if (!string.IsNullOrEmpty(Model.StoryTitle))
            {
                <p class="ec-hero-sub">
                    <i class="bi bi-book"></i> @Model.StoryTitle
                </p>
            }
        </div>
    </div>

    <!-- ── Form ── -->
    <form asp-action="EditChapter" asp-controller="Chapter" method="post" id="ecForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ChapterId" />
        <input type="hidden" asp-for="StoryId" />

        <!-- Thông tin chapter -->
        <p class="ec-section-label">Thông tin chapter</p>
        <div class="ec-card ec-info-card">

            <div class="ec-field">
                <label class="ec-field-label">
                    Số Chapter <span class="ec-required">*</span>
                </label>
                <div class="ec-input-wrap">
                    <i class="bi bi-hash ec-input-icon"></i>
                    <input asp-for="ChapterNumber"
                           class="ec-input ec-input-number"
                           type="number" min="1"
                           required />
                </div>
                <span asp-validation-for="ChapterNumber" class="ec-validation"></span>
            </div>

            <div class="ec-field">
                <label class="ec-field-label">Tiêu đề</label>
                <div class="ec-input-wrap">
                    <i class="bi bi-cursor-text ec-input-icon"></i>
                    <input asp-for="Title"
                           class="ec-input"
                           placeholder="VD: Khởi đầu mới... (tuỳ chọn)" />
                </div>
            </div>

        </div>

        <!-- Hành động nhanh -->
        <p class="ec-section-label">Liên kết nhanh</p>
        <div class="ec-quick-links">
            <a asp-action="ManageImages"
               asp-route-chapterId="@Model.ChapterId"
               class="ec-quick-btn">
                <i class="bi bi-images"></i>
                <span>Quản lý ảnh</span>
            </a>
            <a asp-action="ListChapters" asp-controller="Chapter"
               asp-route-id="@Model.StoryId"
               class="ec-quick-btn">
                <i class="bi bi-list-ul"></i>
                <span>Danh sách chapter</span>
            </a>
        </div>

        <!-- Buttons -->
        <div class="ec-actions">
            <button type="submit" class="ec-btn ec-btn-primary">
                <i class="bi bi-check-lg"></i> Cập nhật
            </button>
            <a asp-action="ListChapters" asp-controller="Chapter"
               asp-route-id="@Model.StoryId"
               class="ec-btn ec-btn-ghost">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>

    </form>

</div>
