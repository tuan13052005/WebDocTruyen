@{
    ViewData["Title"] = "Bảng điều khiển Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var recentUsers = ViewBag.RecentUsers as List<WebDocTruyen.Application.DTOs.User.UserDto> ?? new();
}

<link rel="stylesheet" href="~/css/admin-dashboard.css" />

<div class="adm-wrap">

    <!-- ── Hero ── -->
    <div class="adm-hero">
        <div class="adm-avatar">
            <i class="bi bi-speedometer2"></i>
        </div>
        <div class="adm-meta">
            <h1 class="adm-title">Bảng điều khiển Admin</h1>
            <p class="adm-sub">Tổng quan hệ thống WebĐọcTruyện</p>
        </div>
    </div>

    <!-- ── Người dùng ── -->
    <p class="section-label">Người dùng</p>
    <div class="adm-grid adm-grid-4">
        <div class="stat-card">
            <div class="stat-icon stat-blue"><i class="bi bi-people"></i></div>
            <div>
                <div class="stat-label">Tổng người dùng</div>
                <div class="stat-value">@ViewBag.TotalUsers</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-red"><i class="bi bi-shield-fill"></i></div>
            <div>
                <div class="stat-label">Admin</div>
                <div class="stat-value">@ViewBag.TotalAdmins</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-amber"><i class="bi bi-pencil-square"></i></div>
            <div>
                <div class="stat-label">Editor</div>
                <div class="stat-value">@ViewBag.TotalEditors</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-gray"><i class="bi bi-person"></i></div>
            <div>
                <div class="stat-label">User thường</div>
                <div class="stat-value">@ViewBag.TotalNormalUsers</div>
            </div>
        </div>
    </div>

    <!-- ── Nội dung ── -->
    <p class="section-label">Nội dung</p>
    <div class="adm-grid adm-grid-2">
        <div class="stat-card">
            <div class="stat-icon stat-green"><i class="bi bi-book"></i></div>
            <div>
                <div class="stat-label">Tổng truyện</div>
                <div class="stat-value">@ViewBag.TotalStories</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-purple"><i class="bi bi-collection"></i></div>
            <div>
                <div class="stat-label">Tổng chapter</div>
                <div class="stat-value">@ViewBag.TotalChapters</div>
            </div>
        </div>
    </div>

    <!-- ── Hành động nhanh ── -->
    <p class="section-label">Hành động nhanh</p>
    <div class="adm-actions">
        <a asp-action="ManageUsers" class="action-btn">
            <i class="bi bi-people"></i>
            Quản lý người dùng
        </a>
        <a asp-action="ManageStories" class="action-btn">
            <i class="bi bi-book"></i>
            Quản lý truyện
        </a>
        <a asp-action="Index" asp-controller="Genres" class="action-btn">
            <i class="bi bi-tags"></i>
            Thể loại
        </a>
    </div>

    <!-- ── Người dùng đăng nhập gần đây ── -->
    @if (recentUsers.Any())
    {
        <p class="section-label">Đăng nhập gần đây</p>
        <div class="adm-card">
            @foreach (var u in recentUsers)
            {
                var initials = u.Username?.Length > 0
                    ? u.Username.Substring(0, Math.Min(2, u.Username.Length)).ToUpper()
                    : "?";
                var roleClass = u.Role == "Admin" ? "role-admin" : u.Role == "Editor" ? "role-editor" : "role-user";
                <div class="user-row">
                    <div class="user-avatar">@initials</div>
                    <div class="user-info">
                        <span class="user-name">@u.Username</span>
                        <span class="user-email">@u.Email</span>
                    </div>
                    <div class="user-right">
                        <span class="role-badge @roleClass">@u.Role</span>
                        <span class="user-time">@u.LastLogin?.ToString("dd/MM HH:mm")</span>
                    </div>
                </div>
            }
        </div>
    }

</div>
