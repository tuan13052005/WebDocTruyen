@model IEnumerable<WebDocTruyen.Application.DTOs.Story.StoryDto>
@{
    ViewData["Title"] = "Quản lý truyện - Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string kw = ViewBag.Keyword ?? "";
    string st = ViewBag.Status ?? "";
    string baseUrl = ViewBag.BaseUrl ?? Url.Action("ManageStories")!;
}

<div class="container mt-4">
    <h2 class="mb-3">📚 Quản lý truyện (Admin) <span class="badge bg-secondary fs-6">@ViewBag.TotalItems</span></h2>

    <form asp-action="ManageStories" method="get" class="row g-2 mb-3">
        <div class="col-md-5">
            <input type="text" name="keyword" value="@kw" class="form-control" placeholder="🔍 Tìm tiêu đề, tác giả..." />
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="">-- Trạng thái --</option>
                @if (st == "ongoing")
                {
                    <option value="ongoing" selected>🔄 Đang ra</option>
                }
                else
                {
                    <option value="ongoing">🔄 Đang ra</option>
                }
                @if (st == "completed")
                {
                    <option value="completed" selected>✅ Hoàn thành</option>
                }
                else
                {
                    <option value="completed">✅ Hoàn thành</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="pageSize" class="form-select">
                @foreach (var s in new[] { 10, 15, 25 })
                {
                    if ((int)ViewBag.PageSize == s)
                    {
                        <option value="@s" selected>@s / trang</option>
                    }
                    else
                    {
                        <option value="@s">@s / trang</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-1"><button type="submit" class="btn btn-primary w-100">Lọc</button></div>
        <div class="col-md-1"><a asp-action="ManageStories" class="btn btn-outline-secondary w-100">↺</a></div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Không tìm thấy truyện nào.</div>
    }
    else
    {
        <table class="table table-striped table-hover shadow-sm align-middle">
            <thead class="table-dark">
                <tr><th>ID</th><th>Tiêu đề</th><th>Tác giả</th><th>Trạng thái</th><th>Chapter</th><th>Đánh giá</th><th>Ngày tạo</th><th>Hành động</th></tr>
            </thead>
            <tbody>
                @foreach (var story in Model)
                {
                    <tr>
                        <td>@story.Id</td>
                        <td class="fw-semibold">@story.Title</td>
                        <td>@story.Author</td>
                        <td>
                            @if (story.Status == "completed")
                            {
                                <span class="badge bg-success">Hoàn thành</span>
                            }
                            else
                            {

                                <span class="badge bg-warning text-dark">Đang ra</span>
                            }
                        </td>
                        <td class="text-center">@story.ChapterCount</td>
                        <td class="text-center">★ @story.AvgRating.ToString("F1")</td>
                        <td>@story.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="d-flex gap-1">
                            <a asp-controller="Story" asp-action="Details" asp-route-id="@story.Id" class="btn btn-sm btn-info">👁️</a>
                            <form asp-action="DeleteStory" method="post" onsubmit="return confirm('Xóa truyện này?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@story.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @await Html.PartialAsync("_Pagination", new ViewDataDictionary(ViewData)
        {
        ["CurrentPage"] = ViewBag.CurrentPage,
        ["TotalPages"] = ViewBag.TotalPages,
        ["TotalItems"] = ViewBag.TotalItems,
        ["PageSize"] = ViewBag.PageSize,
        ["BaseUrl"] = baseUrl,
        })
        }
</div>