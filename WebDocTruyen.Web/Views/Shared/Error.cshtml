@model WebDocTruyen.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/error-effects.css" />

<div class="error-container err-card-in" style="position:relative;">
    <span class="err-bg-dot" style="width:80px;height:80px;background:#ef4444;top:-16px;right:-20px;animation-duration:6.5s;"></span>

    <h1 class="err-code-glitch" data-text="@Model.StatusCode">@Model.StatusCode - @Model.Title</h1>
    <p>@Model.Message</p>

    @if (Model.ShowRequestId)
    {
        <p><strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code></p>
    }

    @if (!string.IsNullOrEmpty(Model.Path))
    {
        <p><strong>Đường dẫn:</strong> @Model.Path</p>
    }

    @if (Model.ShowDetails)
    {
        <div class="error-details">
            <h3>Chi tiết kỹ thuật</h3>
            @if (!string.IsNullOrEmpty(Model.ExceptionMessage))
            {
                <p><strong>Exception:</strong> @Model.ExceptionMessage</p>
            }
            @if (!string.IsNullOrEmpty(Model.StackTrace))
            {
                <pre>@Model.StackTrace</pre>
            }
        </div>
    }

    <div class="error-actions">
        <a href="/" class="btn btn-primary err-btn-pulse">Về trang chủ</a>
        <a href="javascript:history.back()" class="btn btn-secondary">Quay lại</a>
    </div>
</div>

<style>
    .error-container {
        max-width: 800px;
        margin: 50px auto;
        padding: 20px;
        border: 1px solid #ddd;
        border-radius: 8px;
        background: #fafafa;
        font-family: Arial, sans-serif;
    }

        .error-container h1 {
            color: #c00;
        }

    .error-details {
        margin-top: 20px;
        background: #fff3f3;
        padding: 10px;
        border: 1px solid #f5c2c2;
        border-radius: 5px;
    }

    .error-actions {
        margin-top: 20px;
    }

        .error-actions .btn {
            margin-right: 10px;
            padding: 8px 16px;
            text-decoration: none;
            border-radius: 4px;
        }

    .btn-primary {
        background-color: #007bff;
        color: white;
    }

    .btn-secondary {
        background-color: #6c757d;
        color: white;
    }
</style>