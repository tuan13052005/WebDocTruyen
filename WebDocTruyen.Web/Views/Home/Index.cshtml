@model List<WebDocTruyen.Application.DTOs.Story.StoryDto>
@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12 mb-4">
            <div class="hero-section text-center">
                <h1 class="fw-bold">Chào mừng đến với WebDocTruyen 📚</h1>
                <p class="lead text-muted">Nơi bạn có thể đọc hàng ngàn truyện tranh và tiểu thuyết trực tuyến.</p>
                <a asp-controller="Story" asp-action="Index" class="btn btn-primary btn-lg">Khám phá ngay</a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-9 col-md-8">
            <h2 class="mb-4">🔥 Truyện mới cập nhật</h2>
            <div class="row">
                @if (Model != null && Model.Any())
                {
                    @foreach (var story in Model)
                    {
                        <div class="col-md-3 col-sm-6 mb-4">
                            <div class="card h-100 shadow-sm">
                                <img src="@story.CoverImage" class="card-img-top" alt="@story.Title"
                                     style="height:200px; object-fit:cover;"
                                     onerror="this.src='/images/default.jpg'" />
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title text-truncate" title="@story.Title">@story.Title</h6>
                                    <p class="card-text text-muted small">
                                        @(story.Status == "completed" ? "✅ Hoàn thành" : "🔄 Đang ra")
                                        &nbsp;·&nbsp; @story.ChapterCount ch.
                                    </p>
                                    <a asp-controller="Story" asp-action="Details" asp-route-id="@story.Id"
                                       class="btn btn-sm btn-primary mt-auto">Đọc ngay</a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">Chưa có truyện nào. Hãy quay lại sau!</p>
                }
            </div>
        </div>

        <div class="col-lg-3 col-md-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">🔎 Tìm kiếm nhanh</h5>
                    <form asp-controller="Story" asp-action="Index" method="get">
                        <input type="text" name="keyword" class="form-control mb-2" placeholder="Nhập tên truyện..." />
                        <select name="status" class="form-select mb-2">
                            <option value="">-- Trạng thái --</option>
                            <option value="ongoing">Đang ra</option>
                            <option value="completed">Hoàn thành</option>
                        </select>

                        @if (ViewBag.Genres != null)
                        {
                            <label class="form-label fw-semibold small text-muted">THỂ LOẠI</label>
                            <div class="border rounded p-2 mb-2" style="max-height:180px;overflow-y:auto;">
                                @foreach (var g in (IEnumerable<WebDocTruyen.Application.DTOs.Genre.GenreDto>)ViewBag.Genres)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               name="genreIds" value="@g.GenreId" id="homeGenre@(g.GenreId)" />
                                        <label class="form-check-label small" for="homeGenre@(g.GenreId)">@g.Name</label>
                                    </div>
                                }
                            </div>
                        }

                        <button type="submit" class="btn btn-primary w-100">Tìm kiếm</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>