@model WebDocTruyen.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/error-effects.css" />

<div class="container mt-5 text-center" style="max-width:600px; margin:auto; position:relative;">
    <span class="err-bg-dot" style="width:90px;height:90px;background:#7c3aed;top:-20px;left:-30px;animation-duration:6s;"></span>
    <span class="err-bg-dot" style="width:60px;height:60px;background:#ec4899;bottom:0;right:-20px;animation-duration:7.5s;animation-delay:.6s;"></span>

    <div class="card shadow-sm border-danger err-card-in">
        <div class="card-body p-5">
            <div class="err-icon-bounce" style="font-size:4rem;">
                @(Model.StatusCode == 404 ? "🔍" : Model.StatusCode == 403 ? "🚫" : "⚠️")
            </div>
            <h1 class="mt-3 text-danger err-code-glitch" data-text="@Model.StatusCode">@Model.StatusCode</h1>
            <h2 class="mb-3">@Model.Title</h2>
            <p class="text-muted">@Model.Message</p>

            @if (Model.ShowRequestId)
            {
                <p class="text-muted small">
                    <strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code>
                </p>
            }

            @if (Model.ShowDetails && !string.IsNullOrEmpty(Model.ExceptionMessage))
            {
                <div class="alert alert-warning text-start mt-4">
                    <strong>Chi tiết lỗi (chỉ hiện ở Development):</strong>
                    <p class="mb-1 mt-2"><code>@Model.ExceptionMessage</code></p>
                    @if (!string.IsNullOrEmpty(Model.Path))
                    {
                        <p class="mb-1"><strong>Path:</strong> <code>@Model.Path</code></p>
                    }
                    @if (!string.IsNullOrEmpty(Model.StackTrace))
                    {
                        <details class="mt-2">
                            <summary class="text-muted small">Stack trace</summary>
                            <pre class="small mt-2" style="white-space:pre-wrap;">@Model.StackTrace</pre>
                        </details>
                    }
                </div>
            }

            <div class="mt-4 d-flex gap-2 justify-content-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary err-btn-pulse">🏠 Về trang chủ</a>
                <a href="javascript:history.back()" class="btn btn-outline-secondary">← Quay lại</a>
            </div>
        </div>
    </div>
</div>