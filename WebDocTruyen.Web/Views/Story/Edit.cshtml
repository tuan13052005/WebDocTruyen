@model WebDocTruyen.Application.DTOs.Story.StoryFormDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Sửa truyện";
}

<div class="container mt-4" style="max-width:700px;">
    <h2 class="mb-4">✏️ Sửa truyện</h2>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="StoryId" />

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Tên truyện</label>
            <input asp-for="Title" class="form-control" required />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Author" class="form-label">Tác giả</label>
            <input asp-for="Author" class="form-control" required />
            <span asp-validation-for="Author" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">Trạng thái</label>
            <select asp-for="Status" class="form-select">
                @if (Model.Status == "ongoing")
                {
                    <option value="ongoing" selected>🔄 Đang ra</option>
                    <option value="completed">✅ Hoàn thành</option>
                }
                else
                {
                    <option value="ongoing">🔄 Đang ra</option>
                    <option value="completed" selected>✅ Hoàn thành</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Ảnh bìa hiện tại</label><br />
            @if (!string.IsNullOrEmpty(Model.CoverImage))
            {
                <img src="@Model.CoverImage" alt="Ảnh bìa" class="img-thumbnail mb-2" style="max-height:200px;" />
            }
            <input type="file" name="coverImage" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
        </div>
        <div class="mb-3">
            <label class="form-label">Thể loại <span class="text-danger">*</span></label>
            <div class="border rounded p-2" style="max-height:220px;overflow-y:auto;">
                @foreach (var genre in (IEnumerable<WebDocTruyen.Application.DTOs.Genre.GenreDto>)ViewBag.Genres)
                {
                    bool isChecked = Model.SelectedGenreIds.Contains(genre.GenreId);
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               name="SelectedGenreIds"
                               value="@genre.GenreId"
                               id="g@(genre.GenreId)"
                               checked="@(isChecked ? "checked" : null)" />
                        <label class="form-check-label" for="g@(genre.GenreId)">@genre.Name</label>
                    </div>
                }
            </div>
            <span asp-validation-for="SelectedGenreIds" class="text-danger"></span>
            <div class="form-text">Chọn ít nhất 1 thể loại.</div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">💾 Lưu thay đổi</button>
            <a asp-action="ManageStories" asp-controller="Editor" class="btn btn-secondary">← Quay lại</a>
        </div>
    </form>
</div>