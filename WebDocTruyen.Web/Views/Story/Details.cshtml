@model WebDocTruyen.Application.DTOs.Story.StoryDetailDto
@using System.Security.Claims
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.Title;

    bool isLoggedIn = User.Identity?.IsAuthenticated == true;
    int uid = isLoggedIn ? int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0") : 0;
    bool isEditor = User.IsInRole("Editor") || User.IsInRole("Admin");
    bool ownsStory = isEditor && Model.CreatedBy == uid;
    int myRatingVal = Model.MyRating ?? 0;
}

<link rel="stylesheet" href="~/css/Story-detail.css" />

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
<input type="hidden" id="ajax-token" value="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />

<div class="sd-wrap">

    <!-- ── HERO ─────────────────────────────────────────────────────── -->
    <div class="sd-hero">
        <div class="sd-hero-bg"></div>
        <div class="sd-hero-dots"></div>
        <div class="sd-orb-1"></div>
        <div class="sd-orb-2"></div>
        <div class="sd-hero-glow"></div>

        <div class="sd-hero-inner">

            <div class="sd-cover-wrap">
                <img src="@Model.CoverImage" alt="@Model.Title" class="sd-cover" />
            </div>

            <div class="sd-info">
                <div class="sd-eyebrow">
                    <span class="sd-eyebrow-dot"></span>
                    Chi tiết truyện
                </div>

                <h1 class="sd-title">@Model.Title</h1>
                <p class="sd-author"><i class="bi bi-pen-fill"></i> @Model.Author</p>

                @if (Model.Genres.Any())
                {
                    <div class="sd-genres">
                        @foreach (var g in Model.Genres)
                        {
                            <a asp-controller="Genres" asp-action="ByGenre" asp-route-id="@g.GenreId"
                               class="sd-genre-tag">@g.Name</a>
                        }
                    </div>
                }

                <div class="sd-badges">
                    @if (Model.Status == "completed")
                    {
                        <span class="sd-badge sd-badge-done"><i class="bi bi-check-circle-fill"></i> Hoàn thành</span>
                    }
                    else
                    {
                        <span class="sd-badge sd-badge-ongoing"><i class="bi bi-arrow-repeat"></i> Đang ra</span>
                    }
                    <span class="sd-badge sd-badge-chap"><i class="bi bi-collection"></i> @Model.ChapterCount chapter</span>
                </div>

                <div class="sd-stats-row">
                    <div class="d-flex align-items-center gap-2">
                        <div class="sd-stars" id="avgStarRow">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="avg-star">@(i <= Math.Round(Model.AvgRating) ? "★" : "☆")</span>
                            }
                        </div>
                        <span class="sd-rating-val" id="avgValBig">@Model.AvgRating.ToString("F1")</span>
                        <span class="sd-rating-count">(<span id="ratingCountTxt">@Model.RatingCount</span> lượt)</span>
                    </div>
                    <span class="sd-fav-count">
                        <i class="bi bi-heart-fill" style="color:#f43f5e;"></i>
                        <span id="favCountTxt">@Model.FavoriteCount</span> lượt theo dõi
                    </span>
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="sd-desc">
                        <p>@Model.Description</p>
                    </div>
                }

                <div class="sd-actions">
                    @if (isLoggedIn && Model.LastReadChapterId.HasValue)
                    {
                        <a asp-action="ReadChapter" asp-controller="Chapter"
                           asp-route-id="@Model.LastReadChapterId" class="sd-btn sd-btn-info">
                            <i class="bi bi-play-fill"></i> Đọc tiếp (Ch.@Model.LastReadChapterNumber)
                        </a>
                    }
                    @if (Model.Chapters.Any())
                    {
                        <a asp-action="ReadChapter" asp-controller="Chapter"
                           asp-route-id="@Model.Chapters.First().ChapterId" class="sd-btn sd-btn-primary">
                            <i class="bi bi-book-half"></i> Đọc từ đầu
                        </a>
                        <a asp-action="ReadChapter" asp-controller="Chapter"
                           asp-route-id="@Model.Chapters.Last().ChapterId" class="sd-btn sd-btn-outline">
                            <i class="bi bi-skip-forward-fill"></i> Chapter mới nhất
                        </a>
                    }
                    @if (isLoggedIn)
                    {
                        <button id="favBtn"
                                onclick="toggleFav(@Model.Id)"
                                class="sd-btn sd-btn-fav @(Model.IsFavorited ? "is-fav" : "")">
                            <i class="bi @(Model.IsFavorited ? "bi-heart-fill" : "bi-heart")"></i>
                            @(Model.IsFavorited ? "Đang theo dõi" : "Theo dõi")
                        </button>
                    }
                    @if (ownsStory)
                    {
                        <a asp-action="Edit" asp-controller="Story" asp-route-id="@Model.Id" class="sd-btn sd-btn-warning">
                            <i class="bi bi-pencil-fill"></i> Sửa
                        </a>
                        <a asp-action="AddChapter" asp-controller="Chapter" asp-route-storyId="@Model.Id" class="sd-btn sd-btn-success">
                            <i class="bi bi-plus-lg"></i> Chapter
                        </a>
                    }
                </div>

                @if (isLoggedIn)
                {
                    <div class="sd-myrating">
                        <div class="sd-myrating-label">Đánh giá của bạn</div>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <div id="myStarRow" class="sd-my-stars"
                                 data-story="@Model.Id" data-current="@myRatingVal">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="sd-my-star my-star" data-v="@i" title="@i điểm">
                                        @(i <= myRatingVal ? "★" : "☆")
                                    </span>
                                }
                            </div>
                            <span id="myScoreLabel" class="sd-myscore-label">
                                @(Model.MyRating.HasValue ? Model.MyRating.ToString() : "Chưa đánh giá")
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ── MỤC LỤC ──────────────────────────────────────────────────── -->
    <div class="sd-section">
        <div class="sd-section-hd">
            <span class="sd-section-title"><i class="bi bi-journal-bookmark-fill"></i> Mục lục (@Model.Chapters.Count chapter)</span>
            @if (Model.Chapters.Count > 15)
            {
                <input id="chapSearch" type="text" class="sd-chap-search" placeholder="Tìm chapter..." />
            }
        </div>

        @if (!Model.Chapters.Any())
        {
            <div class="sd-empty-chap">📭 Truyện này chưa có chapter nào.</div>
        }
        else
        {
            <div class="sd-chap-list">
                @foreach (var chap in Model.Chapters)
                {
                    <div class="sd-chap-row chap-row">
                        <span class="sd-chap-num">@chap.ChapterNumber</span>
                        <a asp-action="ReadChapter" asp-controller="Chapter"
                           asp-route-id="@chap.ChapterId" class="sd-chap-link chap-link">
                            @chap.DisplayTitle
                        </a>
                        <span class="sd-chap-pages">@chap.ImageCount trang</span>
                        @if (ownsStory)
                        {
                            <div class="sd-chap-actions">
                                <a asp-action="ManageImages" asp-controller="Chapter"
                                   asp-route-chapterId="@chap.ChapterId"
                                   class="btn btn-xs btn-outline-primary py-0 px-1">🖼️</a>
                                <a asp-action="EditChapter" asp-controller="Chapter"
                                   asp-route-id="@chap.ChapterId"
                                   class="btn btn-xs btn-outline-warning py-0 px-1">✏️</a>
                                <a asp-action="DeleteChapter" asp-controller="Chapter"
                                   asp-route-id="@chap.ChapterId"
                                   class="btn btn-xs btn-outline-danger py-0 px-1">🗑️</a>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <!-- ── BÌNH LUẬN ────────────────────────────────────────────────── -->
    <div class="sd-section">
        <div class="sd-section-hd">
            <span class="sd-section-title"><i class="bi bi-chat-dots-fill"></i> Bình luận (@Model.Comments.Count)</span>
        </div>
        <div class="sd-comment-body">
            @if (isLoggedIn)
            {
                <form asp-action="AddComment" asp-controller="Story" method="post" class="sd-comment-form mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="storyId" value="@Model.Id" />
                    <textarea name="content" placeholder="Viết bình luận..." required maxlength="1000"></textarea>
                    <button type="submit" class="sd-comment-submit">
                        <i class="bi bi-send-fill"></i> Gửi
                    </button>
                </form>
            }
            else
            {
                <div class="sd-login-hint">
                    <a asp-controller="Account" asp-action="Login">Đăng nhập</a> để bình luận.
                </div>
            }

            @if (!Model.Comments.Any())
            {
                <p class="sd-comment-empty">Chưa có bình luận nào.</p>
            }

            @foreach (var c in Model.Comments)
            {
                <div class="sd-comment-item">
                    <div class="sd-comment-avatar">
                        @(c.Username?.FirstOrDefault().ToString().ToUpper() ?? "?")
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <span class="sd-comment-user">@c.Username</span>
                                <span class="sd-comment-time">@c.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            @if (isLoggedIn && (c.UserId == uid || User.IsInRole("Admin")))
                            {
                                <form asp-action="DeleteComment" asp-controller="Story" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="commentId" value="@c.CommentId" />
                                    <input type="hidden" name="storyId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-xs btn-outline-danger py-0 px-1"
                                            onclick="return confirm('Xóa bình luận?')">
                                        🗑️
                                    </button>
                                </form>
                            }
                        </div>
                        <p class="sd-comment-text">@c.Content</p>
                    </div>
                </div>
            }
        </div>
    </div>

</div>

@section Scripts {
    <script>
        function getAjaxToken() {
            return document.getElementById('ajax-token')?.value ?? '';
        }

        // ── Tìm chapter ──────────────────────────────────────────────────────────
        const chapSearch = document.getElementById('chapSearch');
        if (chapSearch) {
            chapSearch.addEventListener('input', function () {
                const q = this.value.toLowerCase();
                document.querySelectorAll('.chap-row').forEach(r => {
                    r.style.display =
                        r.querySelector('.chap-link')?.textContent?.toLowerCase().includes(q) ? '' : 'none';
                });
            });
        }

        // ── Favorite ──────────────────────────────────────────────────────────────
        async function toggleFav(storyId) {
            const btn = document.getElementById('favBtn');
            btn.disabled = true;
            try {
                const resp = await fetch('/Story/ToggleFavorite', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAjaxToken() },
                    body: `storyId=${storyId}`
                });
                if (!resp.ok) return;
                const d = await resp.json();
                btn.classList.toggle('is-fav', d.favorited);
                btn.innerHTML = d.favorited
                    ? '<i class="bi bi-heart-fill"></i> Đang theo dõi'
                    : '<i class="bi bi-heart"></i> Theo dõi';
                document.getElementById('favCountTxt').textContent = d.count;
            } finally { btn.disabled = false; }
        }

        // ── Rating (1-5) ────────────────────────────────────────────────────────
        (function () {
            const myRow = document.getElementById('myStarRow');
            if (!myRow) return;

            const avgRow  = document.getElementById('avgStarRow');
            const storyId = +myRow.dataset.story;
            let isSending = false;

            function paintMy(score) {
                myRow.querySelectorAll('.my-star').forEach(s => { s.textContent = +s.dataset.v <= score ? '★' : '☆'; });
            }
            function paintAvg(score) {
                avgRow.querySelectorAll('.avg-star').forEach((s, i) => { s.textContent = i + 1 <= score ? '★' : '☆'; });
            }

            myRow.addEventListener('mousemove', e => {
                const star = e.target.closest('.my-star');
                if (star) paintMy(+star.dataset.v);
            });
            myRow.addEventListener('mouseleave', () => paintMy(+myRow.dataset.current));
            myRow.querySelectorAll('.my-star').forEach(s => {
                s.addEventListener('mouseenter', () => s.style.transform = 'scale(1.3)');
                s.addEventListener('mouseleave', () => s.style.transform = '');
            });

            myRow.addEventListener('click', async e => {
                const star = e.target.closest('.my-star');
                if (!star || isSending) return;
                const score = +star.dataset.v;
                isSending = true;
                myRow.style.opacity = '0.6';
                try {
                    const resp = await fetch('/Story/Rate', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAjaxToken() },
                        body: `storyId=${storyId}&score=${score}`
                    });
                    if (!resp.ok) { paintMy(+myRow.dataset.current); return; }
                    const d = await resp.json();
                    myRow.dataset.current = score;
                    paintMy(score);
                    document.getElementById('myScoreLabel').textContent = score;
                    document.getElementById('avgValBig').textContent = d.avg;
                    document.getElementById('ratingCountTxt').textContent = d.count;
                    paintAvg(Math.round(d.avg));
                } finally {
                    isSending = false;
                    myRow.style.opacity = '1';
                }
            });
        })();
    </script>
}
