@model IEnumerable<WebDocTruyen.Application.DTOs.Story.StoryDto>
@{
    ViewData["Title"] = "Danh sách truyện";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var selectedGenres = ViewBag.GenreIds as List<int> ?? new List<int>();
    int currentPage = (int)(ViewBag.Page ?? 1);
    int pageSize = (int)(ViewBag.PageSize ?? 12);
    int totalStories = (int)(ViewBag.TotalStories ?? 0);
    int totalPages = (int)Math.Ceiling((double)totalStories / Math.Max(pageSize, 1));

    string kw = ViewBag.Keyword ?? "";
    string st = ViewBag.Status ?? "";
    string sr = ViewBag.Sort ?? "";

    int pStart = Math.Max(1, currentPage - 3);
    int pEnd = Math.Min(totalPages, pStart + 6);
    pStart = Math.Max(1, pEnd - 6);
    string genreQs = string.Join("&", selectedGenres.Select(id => $"genreIds={id}"));
}

<link rel="stylesheet" href="~/css/story-index.css" />
<link rel="stylesheet" href="~/css/story-effects.css" />

<div class="si-wrap">
    <div class="si-layout">

        <!-- ── SIDEBAR BỘ LỌC ── -->
        <aside class="si-sidebar">
            <form asp-action="Index" method="get" id="filterForm" class="si-filter-form">

                <!-- Header galaxy -->
                <div class="si-filter-head">
                    <div class="si-head-grid"></div>
                    <div class="si-head-inner">
                        <div class="si-eyebrow">
                            <span class="si-eyebrow-dot"></span>
                            Bộ lọc nâng cao
                        </div>
                        <div class="si-head-title">Tìm truyện yêu thích</div>
                        <div class="si-head-sub">Lọc theo thể loại, trạng thái...</div>
                    </div>
                </div>

                <!-- Body -->
                <div class="si-filter-body">

                    <!-- Search -->
                    <div>
                        <p class="si-section-label">Từ khoá</p>
                        <div class="si-search-wrap">
                            <i class="bi bi-search si-search-icon"></i>
                            <input type="text" name="keyword" value="@kw"
                                   class="si-search-input" placeholder="Tên truyện, tác giả..." />
                            @if (!string.IsNullOrEmpty(kw))
                            {
                                <button type="submit" class="si-search-clear"
                                        onclick="document.querySelector('[name=keyword]').value=''"
                                        title="Xóa tìm kiếm">
                                    <i class="bi bi-x"></i>
                                </button>
                            }
                        </div>
                    </div>

                    <!-- Trạng thái -->
                    <div>
                        <p class="si-section-label">Trạng thái</p>
                        <div class="si-status-pills">
                            <label class="si-pill @(string.IsNullOrEmpty(st) ? "is-active" : "")">
                                <input type="radio" name="status" value="" @(string.IsNullOrEmpty(st) ? "checked" : "") hidden />
                                <span class="si-pill-icon">📚</span>
                                <span class="si-pill-label">Tất cả</span>
                            </label>
                            <label class="si-pill si-pill--going @(st == "ongoing" ? "is-active" : "")">
                                <input type="radio" name="status" value="ongoing" @(st == "ongoing" ? "checked" : "") hidden />
                                <span class="si-pill-icon">🔄</span>
                                <span class="si-pill-label">Đang ra</span>
                            </label>
                            <label class="si-pill si-pill--done @(st == "completed" ? "is-active" : "")">
                                <input type="radio" name="status" value="completed" @(st == "completed" ? "checked" : "") hidden />
                                <span class="si-pill-icon">✅</span>
                                <span class="si-pill-label">Xong</span>
                            </label>
                        </div>
                    </div>

                    <!-- Sắp xếp -->
                    <div>
                        <p class="si-section-label">Sắp xếp</p>
                        <div class="si-sort-list">
                            @{
                                var sortOptions = new[]
                                {
                                    ("", "Mới thêm", "linear-gradient(135deg,#7c3aed,#ec4899)"),
                                    ("updated", "Cập nhật gần đây", "#06b6d4"),
                                    ("chapter", "Nhiều chapter", "#f97316"),
                                    ("follow", "Nhiều theo dõi", "#ec4899"),
                                    ("rating", "Đánh giá cao", "#fbbf24"),
                                };
                            }
                            @foreach (var (val, label, color) in sortOptions)
                            {
                                <label class="si-sort-item @(sr == val ? "is-active" : "")">
                                    <input type="radio" name="sort" value="@val" @(sr == val ? "checked" : "") hidden />
                                    <span class="si-sort-dot" style="background:@color"></span>
                                    @label
                                </label>
                            }
                        </div>
                    </div>

                    <!-- Thể loại -->
                    @if (ViewBag.Genres != null)
                    {
                        <div>
                            <p class="si-section-label">Thể loại</p>
                            <div class="si-genre-grid">
                                @foreach (var g in (IEnumerable<WebDocTruyen.Application.DTOs.Genre.GenreDto>)ViewBag.Genres)
                                {
                                    bool sel = selectedGenres.Contains(g.GenreId);
                                    <label class="si-genre-chip @(sel ? "is-active" : "")" for="g@(g.GenreId)">
                                        <input type="checkbox" name="genreIds" value="@g.GenreId"
                                               id="g@(g.GenreId)" @(sel ? "checked" : "") hidden />
                                        @g.Name
                                    </label>
                                }
                            </div>
                        </div>
                    }

                    <!-- Số truyện / trang -->
                    <div>
                        <p class="si-section-label">Hiển thị</p>
                        <div class="si-size-pills">
                            @foreach (var s in new[] { 12, 24, 48 })
                            {
                                <label class="si-size-pill @(pageSize == s ? "is-active" : "")">
                                    <input type="radio" name="pageSize" value="@s"
                                    @(pageSize == s ? "checked" : "") hidden />
                                    @s
                                </label>
                            }
                        </div>
                    </div>

                </div><!-- /si-filter-body -->
                <!-- Actions -->
                <div class="si-filter-actions">
                    <button type="submit" class="si-btn-apply">
                        <i class="bi bi-search"></i> Tìm kiếm
                    </button>
                    <a asp-action="Index" class="si-btn-reset" title="Đặt lại">
                        <i class="bi bi-arrow-counterclockwise"></i> Đặt lại
                    </a>
                </div>

            </form>
        </aside>

        <!-- ── DANH SÁCH TRUYỆN ── -->
        <main class="si-main">

            <!-- Topbar -->
            <div class="si-topbar">
                <div class="si-topbar-left">
                    @if (!string.IsNullOrEmpty(kw))
                    {
                        <span class="si-result-badge">
                            Kết quả &ldquo;<strong>@kw</strong>&rdquo;
                            <a asp-action="Index" class="si-result-clear" title="Xóa">
                                <i class="bi bi-x-circle-fill"></i>
                            </a>
                        </span>
                    }
                    <span class="si-count-label">
                        <strong>@totalStories</strong> truyện
                        @if (totalPages > 1)
                        {
                            <span class="si-count-page"> · trang @currentPage/@totalPages</span>
                        }
                    </span>
                </div>

                <!-- Active chips -->
                <div class="si-active-chips">
                    @if (!string.IsNullOrEmpty(st))
                    {
                        <span class="si-chip">
                            @(st == "completed" ? "✅ Hoàn thành" : "🔄 Đang ra")
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(sr))
                    {
                        string srLabel = sr switch
                        {
                            "updated" => "Cập nhật gần đây",
                            "chapter" => "Nhiều chapter",
                            "follow" => "Nhiều theo dõi",
                            "rating" => "Đánh giá cao",
                            _ => sr
                        };
                        <span class="si-chip">@srLabel</span>
                    }
                    @foreach (var gid in selectedGenres)
                    {
                        var genre = ((IEnumerable<WebDocTruyen.Application.DTOs.Genre.GenreDto>)ViewBag.Genres)
                            .FirstOrDefault(g => g.GenreId == gid);
                        if (genre != null)
                        {
                            <span class="si-chip si-chip--genre">@genre.Name</span>
                        }
                    }
                </div>
            </div>

            <!-- Grid hoặc Empty -->
            @if (Model == null || !Model.Any())
            {
                <div class="si-empty">
                    <div class="si-empty-icon"><i class="bi bi-search"></i></div>
                    <h3>Không tìm thấy truyện nào</h3>
                    <p>Thử thay đổi bộ lọc hoặc từ khoá tìm kiếm.</p>
                    <a asp-action="Index" class="si-btn-reset">
                        <i class="bi bi-arrow-counterclockwise"></i> Xoá bộ lọc
                    </a>
                </div>
            }
            else
            {
                <div class="si-grid">
                    @foreach (var s in Model)
                    {
                        <article class="si-card reveal-card tilt-card glow-border">
                            <a asp-action="Details" asp-route-id="@s.Id" class="si-card-thumb-link">
                                <div class="si-card-thumb">
                                    <img src="@s.CoverImage" alt="@s.Title" loading="lazy" class="img-shimmer"
                                         onerror="this.src='/images/default.jpg'" />
                                    <span class="si-status-dot @(s.Status == "completed" ? "si-dot--done" : "si-dot--going")">
                                        @(s.Status == "completed" ? "✅ Xong" : "🔄 Đang ra")
                                    </span>
                                    <span class="si-card-chap">
                                        <i class="bi bi-collection" style="font-size:9px;"></i> @s.ChapterCount
                                    </span>
                                    @if (s.AvgRating > 0)
                                    {
                                        <span class="si-card-rating">★ @s.AvgRating.ToString("F1")</span>
                                    }
                                </div>
                            </a>
                            <div class="si-card-body">
                                <a asp-action="Details" asp-route-id="@s.Id" class="si-card-title">@s.Title</a>
                                <p class="si-card-author">
                                    <i class="bi bi-person" style="font-size:10px;"></i> @s.Author
                                </p>
                                @if (s.Genres.Any())
                                {
                                    <div class="si-card-genres">
                                        @foreach (var g in s.Genres.Take(2))
                                        {
                                            <a asp-controller="Genres" asp-action="ByGenre" asp-route-id="@g.GenreId"
                                               class="si-genre-tag">@g.Name</a>
                                        }
                                        @if (s.Genres.Count > 2)
                                        {
                                            <span class="si-genre-tag si-genre-more">+@(s.Genres.Count - 2)</span>
                                        }
                                    </div>
                                }
                                <a asp-action="Details" asp-route-id="@s.Id" class="si-card-btn">
                                    Đọc ngay →
                                </a>
                            </div>
                        </article>
                    }
                </div>

                <!-- Phân trang -->
                @if (totalPages > 1)
                {
                    <nav class="si-pagination" aria-label="Phân trang">
                        <a class="si-page-btn @(currentPage == 1 ? "is-disabled" : "")"
                           href="?page=@(currentPage - 1)&pageSize=@pageSize&keyword=@kw&status=@st&sort=@sr&@genreQs"
                           aria-label="Trang trước">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                        @for (int p = pStart; p <= pEnd; p++)
                        {
                            <a class="si-page-btn @(p == currentPage ? "is-current" : "")"
                               href="?page=@p&pageSize=@pageSize&keyword=@kw&status=@st&sort=@sr&@genreQs">
                                @p
                            </a>
                        }
                        <a class="si-page-btn @(currentPage == totalPages ? "is-disabled" : "")"
                           href="?page=@(currentPage + 1)&pageSize=@pageSize&keyword=@kw&status=@st&sort=@sr&@genreQs"
                           aria-label="Trang sau">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </nav>
                }
            }

        </main>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(
            '.si-pill input, .si-sort-item input, .si-genre-chip input, .si-size-pill input'
        ).forEach(function (inp) {
            inp.addEventListener('change', function () {
                document.getElementById('filterForm').submit();
            });
        });

        document.querySelectorAll('.si-genre-chip input').forEach(function (inp) {
            inp.addEventListener('change', function () {
                this.closest('.si-genre-chip').classList.toggle('is-active', this.checked);
            });
        });
    </script>
    <script src="~/js/story-effects.js"></script>
}
