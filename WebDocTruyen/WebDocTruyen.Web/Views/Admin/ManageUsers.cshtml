@model IEnumerable<WebDocTruyen.Domain.Entities.User>
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string kw = ViewBag.Keyword ?? "";
    string roleF = ViewBag.RoleFilter ?? "";
    string baseUrl = ViewBag.BaseUrl ?? Url.Action("ManageUsers")!;
}

<div class="container mt-4">
    <h2 class="mb-3">
        👥 Quản lý người dùng
        <span class="badge bg-secondary fs-6">@ViewBag.TotalItems</span>
    </h2>

    <!-- Thêm tài khoản -->
    <div class="card mb-3 shadow-sm">
        <div class="card-header bg-success text-white">➕ Thêm tài khoản mới</div>
        <div class="card-body">
            <form asp-action="AddUser" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <div class="col-md-3"><input type="text" name="Username" class="form-control" placeholder="Tên đăng nhập" required /></div>
                <div class="col-md-3"><input type="email" name="Email" class="form-control" placeholder="Email" required /></div>
                <div class="col-md-2"><input type="password" name="Password" class="form-control" placeholder="Mật khẩu" required /></div>
                <div class="col-md-2">
                    <select name="Role" class="form-select">
                        <option value="User">User</option>
                        <option value="Admin">Admin</option>
                        <option value="Editor">Editor</option>
                    </select>
                </div>
                <div class="col-md-2"><button type="submit" class="btn btn-success w-100">Thêm</button></div>
            </form>
        </div>
    </div>

    <!-- Bộ lọc + tìm kiếm -->
    <form asp-action="ManageUsers" method="get" class="row g-2 mb-3">
        <div class="col-md-5">
            <input type="text" name="keyword" value="@kw"
                   class="form-control" placeholder="🔍 Tìm theo tên, email..." />
        </div>
        <div class="col-md-3">
            <select name="role" class="form-select">
                <option value="">-- Tất cả role --</option>
                @if (roleF == "Admin")
                {
                    <option value="Admin" selected>Admin</option>
                }
                else
                {
                    <option value="Admin">Admin</option>
                }
                @if (roleF == "Editor")
                {
                    <option value="Editor" selected>Editor</option>
                }
                else
                {
                    <option value="Editor">Editor</option>
                }
                @if (roleF == "User")
                {
                    <option value="User" selected>User</option>
                }
                else
                {
                    <option value="User">User</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="pageSize" class="form-select">
                @foreach (var s in new[] { 10, 15, 25, 50 })
                {
                    if ((int)ViewBag.PageSize == s)
                    {
                        <option value="@s" selected>@s / trang</option>
                    }
                    else
                    {
                        <option value="@s">@s / trang</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-1"><button type="submit" class="btn btn-primary w-100">Lọc</button></div>
        <div class="col-md-1"><a asp-action="ManageUsers" class="btn btn-outline-secondary w-100">↺</a></div>
    </form>

    <!-- Bảng -->
    @if (!Model.Any())
    {
        <div class="alert alert-info">Không tìm thấy người dùng nào.</div>
    }
    else
    {
        <table class="table table-striped table-hover shadow-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>LastLogin</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.UserId</td>
                        <td>@user.Username</td>
                        <td>@user.Email</td>
                        <td>
                            <span class="badge @(user.Role == "Admin" ? "bg-danger" : user.Role == "Editor" ? "bg-warning text-dark" : "bg-secondary")">
                                @user.Role
                            </span>
                        </td>
                        <td>@user.LastLogin?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="d-flex gap-1 flex-wrap">
                            <form asp-action="ChangeRole" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@user.UserId" />
                                <select name="role" class="form-select form-select-sm d-inline w-auto">
                                    @if (user.Role == "User")
                                    {
                                        <option value="User" selected>User</option>
                                    }
                                    else
                                    {
                                        <option value="User">User</option>
                                    }
                                    @if (user.Role == "Admin")
                                    {
                                        <option value="Admin" selected>Admin</option>
                                    }
                                    else
                                    {
                                        <option value="Admin">Admin</option>
                                    }
                                    @if (user.Role == "Editor")
                                    {
                                        <option value="Editor" selected>Editor</option>
                                    }
                                    else
                                    {
                                        <option value="Editor">Editor</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-sm btn-primary">Đổi</button>
                            </form>
                            <form asp-action="DeleteUser" method="post" class="d-inline"
                                  onsubmit="return confirm('Xóa user @user.Username?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@user.UserId" />
                                <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @await Html.PartialAsync("_Pagination", new ViewDataDictionary(ViewData)
        {
        ["CurrentPage"] = ViewBag.CurrentPage,
        ["TotalPages"] = ViewBag.TotalPages,
        ["TotalItems"] = ViewBag.TotalItems,
        ["PageSize"] = ViewBag.PageSize,
        ["BaseUrl"] = baseUrl,
        })
        }
</div>