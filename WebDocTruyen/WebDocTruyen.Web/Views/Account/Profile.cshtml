@model WebDocTruyen.Domain.Entities.User
@{
    ViewData["Title"] = "Trang cá nhân";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5" style="max-width:600px;">
    <h2 class="mb-4 text-center">👤 Trang cá nhân</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <p><strong>Tên đăng nhập:</strong> @Model.Username</p>
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Vai trò:</strong> @Model.Role</p>
            <p><strong>Ngày tạo:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
            <p><strong>Lần đăng nhập gần nhất:</strong> @Model.LastLogin?.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
    </div>

    <div class="mt-3 text-center">
        <a href="/Account/Settings" class="btn btn-primary me-2">⚙️ Cài đặt</a>
        <a href="/Account/ChangePassword" class="btn btn-warning">🔑 Đổi mật khẩu</a>
    </div>
</div>
