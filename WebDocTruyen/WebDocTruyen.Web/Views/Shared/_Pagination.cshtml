@{
    int cur = (int)(ViewData["CurrentPage"] ?? 1);
    int total = (int)(ViewData["TotalPages"] ?? 1);
    int items = (int)(ViewData["TotalItems"] ?? 0);
    int size = (int)(ViewData["PageSize"] ?? 10);
    string baseUrl = ViewData["BaseUrl"]?.ToString() ?? "";

    int pStart = Math.Max(1, cur - 3);
    int pEnd = Math.Min(total, pStart + 6);
    pStart = Math.Max(1, pEnd - 6);

    string PageUrl(int p) => baseUrl.Contains('?')
        ? $"{baseUrl}&page={p}&pageSize={size}"
        : $"{baseUrl}?page={p}&pageSize={size}";
}

@if (total <= 1) { return; }

<div class="d-flex flex-column align-items-center gap-1 mt-3">
    <nav>
        <ul class="pagination pagination-sm mb-0 flex-wrap justify-content-center">

            <li class="page-item @(cur == 1 ? "disabled" : "")">
                <a class="page-link" href="@PageUrl(1)">«</a>
            </li>
            <li class="page-item @(cur == 1 ? "disabled" : "")">
                <a class="page-link" href="@PageUrl(cur - 1)">‹</a>
            </li>

            @for (int p = pStart; p <= pEnd; p++)
            {
                <li class="page-item @(p == cur ? "active" : "")">
                    <a class="page-link" href="@PageUrl(p)">@p</a>
                </li>
            }

            <li class="page-item @(cur == total ? "disabled" : "")">
                <a class="page-link" href="@PageUrl(cur + 1)">›</a>
            </li>
            <li class="page-item @(cur == total ? "disabled" : "")">
                <a class="page-link" href="@PageUrl(total)">»</a>
            </li>

        </ul>
    </nav>
    <p class="text-muted small mb-0">
        Trang @cur / @total &nbsp;·&nbsp; @items mục
    </p>
</div>