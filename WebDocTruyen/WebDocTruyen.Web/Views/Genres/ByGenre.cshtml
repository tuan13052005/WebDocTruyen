@model IEnumerable<WebDocTruyen.Domain.Entities.Story>
@{
    ViewData["Title"] = "Thể loại: " + ViewBag.GenreName;
    Layout = "~/Views/Shared/_Layout.cshtml";
    int cur = (int)(ViewBag.CurrentPage ?? 1);
    int total = (int)(ViewBag.TotalPages ?? 1);
    int items = (int)(ViewBag.TotalItems ?? 0);
    int size = (int)(ViewBag.PageSize ?? 12);
    int genreId = (int)(ViewBag.GenreId ?? 0);

    int ps = Math.Max(1, cur - 3);
    int pe = Math.Min(total, ps + 6);
    ps = Math.Max(1, pe - 6);
    string PageUrl(int p) => Url.Action("ByGenre", new { id = genreId })! + $"?pageSize={size}&page={p}";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">🏷️ @ViewBag.GenreName</h2>
            <p class="text-muted small mb-0">@items truyện</p>
        </div>
        <a asp-action="Index" asp-controller="Genres" class="btn btn-outline-secondary btn-sm">← Tất cả thể loại</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <div style="font-size:3rem;">📭</div>
            <p class="mb-0">Chưa có truyện nào trong thể loại này.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-2 row-cols-sm-3 row-cols-lg-4 g-3">
            @foreach (var s in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm story-card">
                        <div class="position-relative">
                            <img src="@(string.IsNullOrEmpty(s.CoverImage) ? "/images/default.jpg" : s.CoverImage)"
                                 class="card-img-top" alt="@s.Title"
                                 style="height:200px; object-fit:cover;"
                                 onerror="this.src='/images/default.jpg'" />
                            <span class="position-absolute top-0 end-0 m-1 badge @(s.Status == "completed" ? "bg-success" : "bg-warning text-dark")"
                                  style="font-size:.65rem;">
                                @(s.Status == "completed" ? "Hoàn thành" : "Đang ra")
                            </span>
                            <span class="position-absolute bottom-0 start-0 m-1 badge bg-dark" style="font-size:.65rem;">
                                @(s.Chapters?.Count() ?? 0) ch.
                            </span>
                        </div>
                        <div class="card-body p-2 d-flex flex-column">
                            <h6 class="card-title mb-1 text-truncate fw-semibold" title="@s.Title">@s.Title</h6>
                            <p class="card-text text-muted small mb-2 text-truncate">@s.Author</p>
                            <a asp-action="Details" asp-controller="Story" asp-route-id="@s.StoryId"
                               class="btn btn-primary btn-sm mt-auto stretched-link">Chi tiết</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (total > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center flex-wrap">
                    <li class="page-item @(cur == 1 ? "disabled" : "")"><a class="page-link" href="@PageUrl(1)">«</a></li>
                    <li class="page-item @(cur == 1 ? "disabled" : "")"><a class="page-link" href="@PageUrl(cur - 1)">‹</a></li>
                    @for (int p = ps; p <= pe; p++)
                    {
                        <li class="page-item @(p == cur ? "active" : "")">
                            <a class="page-link" href="@PageUrl(p)">@p</a>
                        </li>
                    }
                    <li class="page-item @(cur == total ? "disabled" : "")"><a class="page-link" href="@PageUrl(cur + 1)">›</a></li>
                    <li class="page-item @(cur == total ? "disabled" : "")"><a class="page-link" href="@PageUrl(total)">»</a></li>
                </ul>
                <p class="text-center text-muted small">Trang @cur / @total · @items truyện</p>
            </nav>
        }
    }
</div>

<style>
    .story-card {
        transition: transform .15s, box-shadow .15s;
    }

        .story-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(0,0,0,.12) !important;
        }
</style>