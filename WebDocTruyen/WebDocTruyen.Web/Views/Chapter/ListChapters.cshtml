@model WebDocTruyen.Domain.Entities.Story
@using System.Security.Claims
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Danh sách Chapter - " + Model.Title;
    bool isEditor = User.IsInRole("Editor") || User.IsInRole("Admin");

    // Phân trang chapter
    int chapPage  = (int)(ViewBag.ChapPage  ?? 1);
    int chapPages = (int)(ViewBag.ChapPages ?? 1);
    int chapTotal = (int)(ViewBag.ChapTotal ?? 0);
    int chapSize  = (int)(ViewBag.ChapSize  ?? 20);
    var chapters  = ViewBag.PagedChapters as List<WebDocTruyen.Domain.Entities.Chapter>
                    ?? Model.Chapters.OrderBy(c => c.ChapterNumber).ToList();

    string chapBaseUrl = Url.Action("ListChapters", new { id = Model.StoryId })
                         + $"?chapSize={chapSize}";
    string ChapPageUrl(int p) => $"{chapBaseUrl}&chapPage={p}";
    int ps = Math.Max(1, chapPage - 3);
    int pe = Math.Min(chapPages, ps + 6);
    ps = Math.Max(1, pe - 6);
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-2">
            <img src="@(string.IsNullOrEmpty(Model.CoverImage) ? "/images/default.jpg" : Model.CoverImage)"
                 alt="@Model.Title" class="img-fluid rounded shadow-sm" />
        </div>
        <div class="col-md-10">
            <h2>📖 @Model.Title</h2>
            <p class="text-muted mb-1">Tác giả: @Model.Author</p>
            <p class="mb-2">
                Trạng thái:
                @if (Model.Status == "completed")
                { <span class="badge bg-success">Hoàn thành</span> }
                else
                { <span class="badge bg-warning text-dark">Đang ra</span> }
                &nbsp;
                <span class="badge bg-secondary">@chapTotal chapter</span>
            </p>
            @if (isEditor)
            {
                <a asp-action="AddChapter" asp-controller="Chapter" asp-route-storyId="@Model.StoryId"
                   class="btn btn-success btn-sm">➕ Thêm Chapter mới</a>
            }
        </div>
    </div>

    <!-- Điều chỉnh số chapter / trang -->
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0">📑 Danh sách Chapter</h5>
        <form asp-action="ListChapters" asp-route-id="@Model.StoryId" method="get" class="d-flex gap-2">
            <select name="chapSize" class="form-select form-select-sm" style="width:auto;"
                    onchange="this.form.submit()">
                @foreach (var s in new[]{10,20,50,100})
                {
                    if (chapSize == s) { <option value="@s" selected>@s / trang</option> }
                    else              { <option value="@s">@s / trang</option> }
                }
            </select>
        </form>
    </div>

    @if (!chapters.Any())
    {
        <div class="alert alert-info">Truyện này chưa có chapter nào.</div>
    }
    else
    {
        <table class="table table-striped table-hover shadow-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width:60px;">Số</th>
                    <th>Tiêu đề</th>
                    <th class="text-center" style="width:90px;">Trang</th>
                    @if (isEditor) { <th style="width:160px;">Thao tác</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var chap in chapters)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@chap.ChapterNumber</span></td>
                        <td>
                            <a asp-action="ReadChapter" asp-controller="Chapter"
                               asp-route-id="@chap.ChapterId"
                               class="text-decoration-none fw-semibold">
                                @(string.IsNullOrEmpty(chap.Title) ? $"Chapter {chap.ChapterNumber}" : chap.Title)
                            </a>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-info text-dark">@chap.ChapterImages.Count</span>
                        </td>
                        @if (isEditor)
                        {
                            <td class="d-flex gap-1">
                                <a asp-action="ManageImages" asp-controller="Chapter"
                                   asp-route-chapterId="@chap.ChapterId"
                                   class="btn btn-sm btn-primary" title="Quản lý ảnh">🖼️</a>
                                <a asp-action="EditChapter" asp-controller="Chapter"
                                   asp-route-id="@chap.ChapterId"
                                   class="btn btn-sm btn-warning" title="Sửa">✏️</a>
                                <a asp-action="DeleteChapter" asp-controller="Chapter"
                                   asp-route-id="@chap.ChapterId"
                                   class="btn btn-sm btn-danger" title="Xóa">🗑️</a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>

        <!-- Phân trang chapter -->
        @if (chapPages > 1)
        {
            <div class="d-flex flex-column align-items-center gap-1 mt-3">
                <nav>
                    <ul class="pagination pagination-sm mb-0 flex-wrap justify-content-center">
                        <li class="page-item @(chapPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="@ChapPageUrl(1)">«</a>
                        </li>
                        <li class="page-item @(chapPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="@ChapPageUrl(chapPage - 1)">‹</a>
                        </li>
                        @for (int p = ps; p <= pe; p++)
                        {
                            <li class="page-item @(p == chapPage ? "active" : "")">
                                <a class="page-link" href="@ChapPageUrl(p)">@p</a>
                            </li>
                        }
                        <li class="page-item @(chapPage == chapPages ? "disabled" : "")">
                            <a class="page-link" href="@ChapPageUrl(chapPage + 1)">›</a>
                        </li>
                        <li class="page-item @(chapPage == chapPages ? "disabled" : "")">
                            <a class="page-link" href="@ChapPageUrl(chapPages)">»</a>
                        </li>
                    </ul>
                </nav>
                <p class="text-muted small mb-0">Trang @chapPage / @chapPages · @chapTotal chapter</p>
            </div>
        }
    }

    <a asp-controller="Story" asp-action="Details" asp-route-id="@Model.StoryId"
       class="btn btn-outline-secondary mt-3">← Về trang truyện</a>
</div>