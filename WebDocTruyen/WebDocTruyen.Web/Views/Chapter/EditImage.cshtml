@model WebDocTruyen.Domain.Entities.ChapterImage
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = $"Sửa ảnh trang {Model.PageNumber}";
    var chapter = ViewBag.Chapter as WebDocTruyen.Domain.Entities.Chapter;
}

<div class="container mt-4" style="max-width:600px;">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-action="ListChapters" asp-controller="Chapter"
                   asp-route-id="@chapter?.StoryId">Danh sách chapter</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="ManageImages" asp-route-chapterId="@Model.ChapterId">
                    Chapter @chapter?.ChapterNumber
                </a>
            </li>
            <li class="breadcrumb-item active">Sửa trang @Model.PageNumber</li>
        </ol>
    </nav>

    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark fw-semibold">
            ✏️ Sửa ảnh — Trang @Model.PageNumber
        </div>
        <div class="card-body">

            <!-- Ảnh hiện tại -->
            <div class="text-center mb-4">
                <p class="text-muted small mb-1">Ảnh hiện tại:</p>
                <img src="@Model.ImageUrl" id="currentPreview"
                     style="max-height:300px; max-width:100%; object-fit:contain; border:1px solid #dee2e6; border-radius:8px;" />
            </div>

            <form asp-action="EditImage" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="imageId" value="@Model.ImageId" />

                <!-- Số trang -->
                <div class="mb-3">
                    <label class="form-label">Số trang <span class="text-danger">*</span></label>
                    <input type="number" name="pageNumber" value="@Model.PageNumber"
                           class="form-control" min="1" required />
                    <div class="form-text">Nhập số trang mới nếu muốn đổi vị trí ảnh này.</div>
                </div>

                <!-- Thay ảnh mới (tuỳ chọn) -->
                <div class="mb-3">
                    <label class="form-label">Thay bằng ảnh mới <span class="text-muted">(tuỳ chọn)</span></label>
                    <input type="file" name="newImageFile" class="form-control"
                           accept=".jpg,.jpeg,.png,.gif,.webp" id="newImageInput" />
                    <div class="form-text">Nếu không chọn file mới, ảnh cũ sẽ được giữ nguyên.</div>

                    <!-- Preview ảnh mới -->
                    <div id="newPreview" class="mt-2 d-none">
                        <p class="text-muted small mb-1">Ảnh mới:</p>
                        <img id="newPreviewImg"
                             style="max-height:200px; max-width:100%; object-fit:contain; border:1px solid #0d6efd; border-radius:8px;" />
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">💾 Lưu thay đổi</button>
                    <a asp-action="ManageImages" asp-route-chapterId="@Model.ChapterId"
                       class="btn btn-outline-secondary">← Huỷ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('newImageInput').addEventListener('change', function () {
            const file = this.files[0];
            const previewDiv = document.getElementById('newPreview');
            const previewImg = document.getElementById('newPreviewImg');

            if (file) {
                const reader = new FileReader();
                reader.onload = e => {
                    previewImg.src = e.target.result;
                    previewDiv.classList.remove('d-none');
                };
                reader.readAsDataURL(file);
            } else {
                previewDiv.classList.add('d-none');
            }
        });
    </script>
}