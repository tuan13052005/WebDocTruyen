@* Partial: thanh điều hướng chapter — dùng chung trên và dưới trang đọc *@
@{
    var chapter = ViewData["Model"] as WebDocTruyen.Domain.Entities.Chapter;
    var prev = ViewData["Prev"] as WebDocTruyen.Domain.Entities.Chapter;
    var next = ViewData["Next"] as WebDocTruyen.Domain.Entities.Chapter;
    var allChapters = ViewData["AllChapters"] as List<WebDocTruyen.Domain.Entities.Chapter> ?? new();
    var story = ViewData["Story"] as WebDocTruyen.Domain.Entities.Story;
    int pageSize = ViewData["PageSize"] is int ps ? ps : 10;
}

<div class="d-flex align-items-center justify-content-between gap-2 my-3 flex-wrap">

    <!-- Nút chapter trước -->
    <div style="min-width:120px;">
        @if (prev != null)
        {
            <a id="prevChapterBtn"
               asp-action="ReadChapter" asp-controller="Chapter"
               asp-route-id="@prev.ChapterId" asp-route-page="1" asp-route-pageSize="@pageSize"
               class="btn btn-outline-secondary w-100">
                ‹ Chapter @prev.ChapterNumber
            </a>
        }
        else
        {
            <button class="btn btn-outline-secondary w-100" disabled>‹ Đầu truyện</button>
        }
    </div>

    <!-- Dropdown chọn chapter -->
    @* FIX RZ1031: không dùng @(...) trong attribute của <option> tag helper
       Thay bằng javascript onchange + selected check bằng C# nếu cần *@
    <div class="flex-grow-1" style="max-width:340px;">
        <select class="form-select text-center"
                onchange="window.location='/Chapter/ReadChapter/' + this.value + '?page=1&pageSize=@pageSize'">
            @foreach (var c in allChapters)
            {
                var label = string.IsNullOrEmpty(c.Title)
                ? $"Chapter {c.ChapterNumber}"
                : $"Chapter {c.ChapterNumber}: {c.Title}";
                var isSelected = c.ChapterId == chapter?.ChapterId;
                if (isSelected)
                {
                    <option value="@c.ChapterId" selected>@label</option>
                }
                else
                {
                    <option value="@c.ChapterId">@label</option>
                }
            }
        </select>
    </div>

    <!-- Nút chapter sau -->
    <div style="min-width:120px;">
        @if (next != null)
        {
            <a id="nextChapterBtn"
               asp-action="ReadChapter" asp-controller="Chapter"
               asp-route-id="@next.ChapterId" asp-route-page="1" asp-route-pageSize="@pageSize"
               class="btn btn-primary w-100">
                Chapter @next.ChapterNumber ›
            </a>
        }
        else
        {
            <button class="btn btn-primary w-100" disabled>Hết truyện</button>
        }
    </div>

</div>

<!-- Nút về trang truyện -->
<div class="text-center mb-1">
    <a asp-action="Details" asp-controller="Story" asp-route-id="@story?.StoryId"
       class="btn btn-sm btn-outline-dark">
        📚 Về trang truyện
    </a>
</div>